# Node
node_modules/
*.log
npm-debug.log*

# pnpm — plugin-local lock = publish 시 `pnpm install --ignore-workspace` 가 생성하는 transient 부산물
#   (워크스페이스 lock = repo-root pnpm-lock.yaml 만 SSOT / plugin-local 은 커밋 안 함)
plugins/*/pnpm-lock.yaml

# Build artifacts (build-plugin.js → repo-root dist/<plugin>-v<ver>/)
dist/

# Cloned source (PoC analysis only — re-clone via git)
plugins/context-ops/examples/poc-03-realworld-nestjs/source/nestjs-realworld-tmp/

# Tool output
**/tools/static-runner/out/
*.sarif
*.stdout.log
*.stderr.log

# codegraph index (machine-local SQLite knowledge graph — re-index per machine via codegraph)
.codegraph/

# companion-tool runtime marker dirs (codegraph-nudge / graph-context-nudge once-per-prompt markers)
**/.static-tools/

# repo-root dogfood session-handoff working context (session-handoff skill writes .ai-context/HANDOFF.md).
# 루트 한정(leading /) — examples/poc-*/.ai-context/ 의 커밋된 산출물 SSOT 167건은 보호(블랭킷 ❌).
/.ai-context/

# Claude Code local settings
.claude/settings.local.json
.claude/worktrees/
# 세션-로컬 스크래치 (매 세션 갱신 = 추적 시 churn / SSOT 아님)
.claude/scheduled_tasks.lock
.claude/workflows/

# OS
.DS_Store
Thumbs.db

# Editor
.idea/
.vscode/
*.swp

# 임시 dogfood — repo-root project-level .mcp.json (headroom/codegraph companion 수동 검증용 / 절대경로 launcher).
