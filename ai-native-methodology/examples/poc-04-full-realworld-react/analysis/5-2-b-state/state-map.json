    {
      "id": "SM-FAVORITE-TOGGLE",
      "purpose": "★ optimistic update — favorite article (★ 3 컴포넌트 isomorphic)",
      "five_truths": ["server_cache", "dom"],
      "binding_component": ["HomeFavoriteButton", "FavoriteArticleButton (article)", "ProfileFavoriteButton (★ Stage 5 신규)"],
