      "id": "SM-LOGIN-FORM",
      "purpose": "★ 진실 #4 form — Login form lifecycle",
      "five_truths": ["form"],
      "binding_component": "LoginPage",
      "initial_state": "idle",
      "states": {
        "idle": {"on": {"SUBMIT": "validating"}},
        "validating": {"invoke": {"src": "validateSchema (Zod LoginUserRequest)", "onDone": "submitting", "onError": "validation-error"}},
        "submitting": {"invoke": {"src": "POST /users/login", "onDone": "success", "onError": "auth-error"}},
        "validation-error": {"on": {"RETRY": "validating"}},
        "auth-error": {"on": {"RETRY": "validating"}},
        "success": {"type": "final", "actions": ["setToken", "queryClient.setQueryData(currentUser)", "redirect(/settings)"]}
      }
    },
    {
      "id": "SM-REGISTER-FORM",
      "purpose": "★ 진실 #4 form — Register form (★ Stage 5 신규 SM)",
