    {"from": "DB", "to": "UserRepo", "label": "★★ race window 시 favoriteCount += 2 (count != favorites.length)", "sync": "return"},

    {"from": "Service", "to": "ArticleRepo", "label": "save(article)", "sync": "sync"},
    {"from": "ArticleRepo", "to": "DB", "label": "UPDATE article SET favoriteCount=?", "sync": "sync"},

    {"from": "Service", "to": "Controller", "label": "article (with favorited:true)", "sync": "return"},
    {"from": "Controller", "to": "Authenticated", "label": "200 OK", "sync": "return"}
