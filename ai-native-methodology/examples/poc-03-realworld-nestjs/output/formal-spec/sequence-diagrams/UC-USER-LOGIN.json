  "actors": [
    {"id": "Client", "type": "user"},
    {"id": "ValidationPipe", "type": "framework"},
    {"id": "Controller", "type": "controller", "name": "UserController"},
    {"id": "Service", "type": "service", "name": "UserService"},
    {"id": "Repository", "type": "repository", "name": "Repository<UserEntity>"},
    {"id": "DB", "type": "external", "name": "MySQL user"},
    {"id": "Argon2", "type": "external", "name": "argon2.verify"},
    {"id": "JWT", "type": "external", "name": "jwt.sign"}
  ],
  "messages": [
    {"from": "Client", "to": "ValidationPipe", "label": "POST /api/users/login {user: LoginUserDto}", "sync": "sync"},
    {"from": "ValidationPipe", "to": "Controller", "label": "@IsNotEmpty 검증", "sync": "sync"},
    {"from": "Controller", "to": "Service", "label": "findOne({email, password: plain})", "sync": "sync", "guard": "★ NestJS Passport ❌ — manual auth"},

    {"from": "Service", "to": "Repository", "label": "findOne({where: {email}})", "sync": "sync"},
    {"from": "Repository", "to": "DB", "label": "SELECT * FROM user WHERE email=?", "sync": "sync"},
    {"from": "DB", "to": "Repository", "label": "row | null", "sync": "return"},
    {"from": "Repository", "to": "Service", "label": "UserEntity | null", "sync": "return"},

    {"from": "Service", "to": "Controller", "label": "throw HttpException 'User not found' 401", "sync": "return", "guard": "row null"},
    {"from": "Controller", "to": "Client", "label": "401 Unauthorized", "sync": "return"},

    {"from": "Service", "to": "Argon2", "label": "argon2.verify(user.password, plainPassword)", "sync": "sync"},
    {"from": "Argon2", "to": "Service", "label": "boolean", "sync": "return"},

    {"from": "Service", "to": "Controller", "label": "throw HttpException 'User not found' 401", "sync": "return", "guard": "★ verify=false → 메시지가 password mismatch 도 포괄 (모호 — F-150 신규)"},
    {"from": "Controller", "to": "Client", "label": "401 Unauthorized", "sync": "return"},

    {"from": "Service", "to": "JWT", "label": "jwt.sign({email, exp: now+60days})", "sync": "sync", "guard": "★ F-118 / F-119 verify 무방어 + 60일"},
    {"from": "JWT", "to": "Service", "label": "token", "sync": "return"},

    {"from": "Service", "to": "Controller", "label": "{user: {email, username, bio, image, token}}", "sync": "return"},
    {"from": "Controller", "to": "Client", "label": "200 OK", "sync": "return"}
  ],
