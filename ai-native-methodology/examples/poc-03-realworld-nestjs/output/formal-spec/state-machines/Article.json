{
  "$schema": "https://ai-native-methodology/schemas/formal-spec.schema.json#/properties/state_machines/items",
  "aggregate_root": "Article",
  "id": "Article",
  "initial": "draft_unrepresented",
  "source_of_truth": "code",
  "direction": "B",
  "focus": "counter aggregate (favoriteCount 단조성 + slug 가변성) — Senior 권고 (research-poc03 §3.1)",
  "evidence_files": [
    {"path": "src/article/article.service.ts"},
    {"path": "src/article/article.entity.ts"},
    {"path": "src/article/article.controller.ts"}
  ],
  "related_brs": [
    "BR-ARTICLE-SLUG-AUTO-001",
    "BR-ARTICLE-FAVORITE-IDEMPOTENT-001",
    "BR-ARTICLE-UNFAVORITE-IDEMPOTENT-001",
    "BR-ARTICLE-AUTHOR-AUTO-001",
    "BR-ARTICLE-COMMENT-EAGER-001"
  ],
  "states": {
    "draft_unrepresented": {
      "type": "transient_pseudo",
      "comment": " RealWorld 스펙 = draft 상태 명시 부재 — 즉시 published 단일 상태",
      "on": {
        "CREATE": "creating"
      }
    },
    "creating": {
      "type": "compound",
      "on": {
        "SLUGIFY_RANDOM": "persistingArticle",
        "AUTHOR_AUTO": {"target": "creating", "actions": ["author = userRepository.findOne(userId)"], "guard": "BR-ARTICLE-AUTHOR-AUTO-001"}
      }
    },
    "persistingArticle": {
      "type": "compound",
      "on": {
        "INSERT_OK": "published_count0",
        "SLUG_COLLISION": {"target": "published_count0", "actions": [" F-053 변형 — random suffix 의존 / DB UQ 부재 / 충돌 시 undefined behavior"], "guard": " F-120 — slug UQ 부재"}
      }
    },
    "published_count0": {
      "comment": "favoriteCount = 0 / commentCount eager loaded",
      "on": {
        "FAVORITE": "favoring",
        "UPDATE": "updating",
        "DELETE": "deleted",
        "ADD_COMMENT": "published_count0",
        "GET": {"target": "published_count0", "actions": [" F-124 — comments eager:true → N+1"]}
      }
    },
    "favoring": {
      "type": "compound",
      "on": {
        "NEW_FAVORITE": {"target": "published_countN", "actions": ["push + favoriteCount++"], "guard": "isNewFavorite"},
        "ALREADY_FAVORITED": {"target": "published_countN", "actions": ["silent skip"], "guard": "App 1중 idempotent"},
        "RACE_DOUBLE_INC": {"target": "published_countN", "actions": [" F-135 critical — 두 동시 favorite 모두 isNewFavorite=true 통과 → favoriteCount 2회 증가 (App 1중 race-prone)"], "guard": " favoriteCount race window"}
      }
    },
    "published_countN": {
      "on": {
        "FAVORITE_DUP": {"target": "published_countN", "actions": ["silent skip"], "guard": "isNewFavorite=false"},
        "UNFAVORITE": "unfavoring",
        "UPDATE": "updating",
        "DELETE": "deleted"
      }
    },
    "unfavoring": {
      "type": "compound",
      "on": {
        "INDEX_FOUND": {"target": "published_count0_or_N", "actions": ["splice + favoriteCount--"], "guard": "deleteIndex >= 0"},
        "INDEX_NOT_FOUND": {"target": "published_countN", "actions": ["silent skip"], "guard": "deleteIndex < 0 = idempotent"}
      }
    },
    "published_count0_or_N": {
      "comment": " 단조성 invariant — favoriteCount = favorites.length (App level 만 보장)",
      "on": {
        "FAVORITE": "favoring",
        "UNFAVORITE": "unfavoring",
        "UPDATE": "updating",
        "DELETE": "deleted"
      }
    },
    "updating": {
      "type": "compound",
      "on": {
        "APPLY_OK": {"target": "published_countN", "actions": [" F-126 — slug 미업데이트 (TODO 주석)"], "guard": "title 변경 시에도 slug regeneration 부재"}
      }
    },
    "deleted": {
      "type": "final",
      "on": {}
    }
  },
  "findings": [
    {"id": "F-120", "summary": " slug UQ 부재 → random suffix 충돌 시 undefined behavior"},
    {"id": "F-124", "summary": " comments eager:true → N+1 (PoC #02 F-051 cross-val 재현)"},
    {"id": "F-126", "summary": " Update 시 slug 미업데이트 (TODO 주석)"},
    {"id": "F-135", "summary": " favoriteCount race window — App 1중 isNewFavorite check / 두 동시 favorite 시 count 2회 증가"},
    {"id": "F-053-variant", "summary": " slugify random suffix (slug unique 회피) — PoC #02 F-053 cross-val 변형 재현"}
  ]
}
