    {"id": "Service", "type": "service", "name": "UserRelationshipService"},
    {"id": "Domain", "type": "domain", "name": "UserFollow (생성자)"},
    {"id": "Repository", "type": "repository", "name": "UserRelationshipRepository (JPA Adapter)"},
    {"id": "DB", "type": "external", "name": "DB"}
  ],
  "messages": [
    {"from": "Client", "to": "Controller", "label": "POST /profiles/B/follow (Auth: A)", "sync": "sync"},
    {"from": "Controller", "to": "Service", "label": "follow(A, B)", "sync": "sync"},

    {"from": "Service", "to": "Repository", "label": "existsBy(A, B)", "sync": "sync", "guard": "BR-USER-FOLLOW-IDEMPOTENT-001"},
    {"from": "Repository", "to": "DB", "label": "SELECT EXISTS(...)", "sync": "sync"},
    {"from": "DB", "to": "Repository", "label": "true", "sync": "return", "guard": "이미 follow 상태"},
    {"from": "Repository", "to": "Service", "label": "true", "sync": "return"},
    {"from": "Service", "to": "Controller", "label": "void (NoOp silent)", "sync": "return"},
    {"from": "Controller", "to": "Client", "label": "200 OK", "sync": "return"},

    {"from": "DB", "to": "Repository", "label": "false", "sync": "return", "guard": "신규 follow"},
    {"from": "Repository", "to": "Service", "label": "false", "sync": "return"},

    {"from": "Service", "to": "Domain", "label": "new UserFollow(A, A)", "sync": "sync", "guard": "★ F-074 fix — BR-USER-FOLLOW-NO-SELF-001"},
    {"from": "Domain", "to": "Domain", "label": "A.id.equals(A.id) ✅", "sync": "sync"},
    {"from": "Domain", "to": "Service", "label": "throw IAE 'follower and following must be different'", "sync": "return"},
    {"from": "Service", "to": "Controller", "label": "IAE propagate", "sync": "return"},
    {"from": "Controller", "to": "Client", "label": "400 Bad Request", "sync": "return"},

    {"from": "Service", "to": "Domain", "label": "new UserFollow(A, B)", "sync": "sync", "guard": "정상 (A ≠ B)"},
    {"from": "Domain", "to": "Service", "label": "UserFollow 인스턴스", "sync": "return"},
    {"from": "Service", "to": "Repository", "label": "save(userFollow)", "sync": "sync"},
    {"from": "Repository", "to": "DB", "label": "INSERT (follower=A, following=B)", "sync": "sync"},

    {"from": "DB", "to": "Repository", "label": "DataIntegrityViolation ★", "sync": "return", "guard": "UQ 충돌 (race window)"},
    {"from": "Repository", "to": "Service", "label": "미처리 propagate", "sync": "return"},
    {"from": "Service", "to": "Controller", "label": "500 Internal Error ★ F-095 — F-058 isomorphic", "sync": "return"},
    {"from": "Controller", "to": "Client", "label": "500", "sync": "return"},

    {"from": "DB", "to": "Repository", "label": "INSERT OK", "sync": "return", "guard": "정상"},
    {"from": "Repository", "to": "Service", "label": "void", "sync": "return"},
    {"from": "Service", "to": "Controller", "label": "void", "sync": "return"},
    {"from": "Controller", "to": "Client", "label": "201 Created", "sync": "return"},

    {"from": "Client", "to": "Controller", "label": "DELETE /profiles/B/follow (Auth: A)", "sync": "sync", "guard": "★ UC-USER-UNFOLLOW"},
    {"from": "Controller", "to": "Service", "label": "unfollow(A, B)", "sync": "sync"},
    {"from": "Service", "to": "Repository", "label": "existsBy(A, B)", "sync": "sync"},
    {"from": "Repository", "to": "DB", "label": "SELECT EXISTS(...)", "sync": "sync"},
    {"from": "DB", "to": "Repository", "label": "true", "sync": "return", "guard": "이미 follow 상태"},
    {"from": "Repository", "to": "Service", "label": "true", "sync": "return"},
    {"from": "Service", "to": "Repository", "label": "deleteBy(A, B)", "sync": "sync"},
    {"from": "Repository", "to": "DB", "label": "DELETE WHERE follower=A, following=B", "sync": "sync"},
    {"from": "DB", "to": "Repository", "label": "1 row deleted", "sync": "return"},
    {"from": "Repository", "to": "Service", "label": "void", "sync": "return"},
    {"from": "Service", "to": "Controller", "label": "void", "sync": "return"},
    {"from": "Controller", "to": "Client", "label": "204 No Content", "sync": "return"},

    {"from": "DB", "to": "Repository", "label": "false", "sync": "return", "guard": "미-follow (idempotent NoOp)"},
    {"from": "Repository", "to": "Service", "label": "false", "sync": "return"},
    {"from": "Service", "to": "Controller", "label": "void (NoOp silent) ★ 자연어 미명시 (F-096)", "sync": "return"},
    {"from": "Controller", "to": "Client", "label": "200 OK", "sync": "return"}
  ],
  "formalization_decisions": [
    "F-074 검증 위치 = Domain (생성자)",
    "거부 방식 = IAE",
    "HTTP = 400 (검증) / 500 (race) / 201 (정상) / 204 (unfollow OK) / 200 (NoOp)",
    "F-095 race window = catch + silent (idempotent 정합)"
  ],
  "findings": [
    {"id": "F-074", "summary": "self-follow 검증 부재"},
    {"id": "F-095", "summary": "race window 처리 미구현 (F-058 isomorphic)"},
    {"id": "F-096", "summary": "unfollow NoOp 자연어 미명시"},
    {"id": "F-097", "summary": "@Transactional 부재 (high — Senior+Static double_hit ★★)"}
  ]
}
