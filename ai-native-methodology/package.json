{
  "name": "@ai-native-methodology/plugin",
  "version": "12.13.1",
  "private": false,
  "type": "module",
  "description": "AI-Native 개발 방법론 — SDLC 6단계 chain harness Claude Code plugin (사내 표준). npm 배포 페이로드(source:npm) + chain/analysis 검증 도구 workspace. 산출물 json 단독 SSOT (v12).",
  "license": "UNLICENSED",
  "homepage": "https://github.smilegate.net/SGH-ISD/ai-native-methodology",
  "author": {
    "name": "MIS",
    "email": "sangcl@smilegate.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.smilegate.net/SGH-ISD/ai-native-methodology.git",
    "directory": "ai-native-methodology"
  },
  "files": [
    ".claude-plugin",
    "agents",
    "skills",
    "hooks",
    "flows",
    "tools",
    "templates",
    "methodology-spec",
    "schemas",
    "guides",
    "scripts/install-static-tools.js",
    "scripts/install-static-tools.sh",
    "CHANGELOG.md",
    "CHANGELOG-HISTORY.md",
    "README.md",
    "!**/test",
    "!**/tests",
    "!**/__tests__",
    "!**/fixtures",
    "!**/corpus",
    "!**/coverage",
    "!**/*.test.js",
    "!templates/adoption"
  ],
  "workspaces": [
    "tools/drift-validator",
    "tools/decision-table-validator",
    "tools/formal-spec-link-validator",
    "tools/spectral-runner",
    "tools/static-runner",
    "tools/schema-validator",
    "tools/discovery-extraction-validator",
    "tools/chain-coverage-validator",
    "tools/spec-test-link-validator",
    "tools/traceability-matrix-builder",
    "tools/test-impl-pass-validator",
    "tools/chain-driver",
    "tools/characterization-coverage-validator",
    "tools/sql-inventory-validator",
    "tools/findings-aggregator",
    "tools/br-cross-consistency-validator",
    "tools/skill-citation-validator",
    "tools/inflation-lint",
    "tools/code-pointer-validator",
    "tools/graph-integrity-validator",
    "tools/plan-coverage-validator",
    "tools/analysis-extraction-validator",
    "tools/codegraph-runner",
    "tools/greenfield-bootstrap",
    "tools/db-assets-validator",
    "tools/adopter-evidence-packager",
    "tools/context-federator",
    "tools/codegraph-coverage"
  ],
  "scripts": {
    "build": "node scripts/build-plugin.js",
    "build:check": "node scripts/build-plugin.js --check",
    "version:check": "node scripts/version-check.js",
    "build:diff-check": "node scripts/build-plugin.js && git diff --exit-code -- .claude-plugin agents skills hooks flows tools templates methodology-spec schemas CHANGELOG.md README.md",
    "test": "npm run test --workspaces --if-present",
    "test:tools": "npm run test --workspaces --if-present",
    "test:chain": "npm run test --workspace=tools/discovery-extraction-validator --workspace=tools/chain-coverage-validator --workspace=tools/spec-test-link-validator --workspace=tools/traceability-matrix-builder --workspace=tools/test-impl-pass-validator --workspace=tools/chain-driver",
    "test:release": "node --test scripts/test/release-readiness.test.js",
    "release:check": "node scripts/release-readiness.js",
    "publish:plugin": "node scripts/publish.js",
    "publish:plugin:dry": "node scripts/publish.js --dry-run",
    "publish:catalog": "node scripts/publish-catalog.js",
    "publish:catalog:dry": "node scripts/publish-catalog.js --dry-run"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "fast-xml-parser": "^4.5.0"
  },
  "bundledDependencies": [
    "ajv",
    "ajv-formats",
    "fast-xml-parser"
  ],
  "publishConfig": {
    "registry": "https://repo.smiledev.net/repository/npm-hosted/"
  }
}
