<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN" "http://www.ibatis.com/dtd/sql-map-2.dtd">
<!-- ★ v8.7.1 PATCH (F-CYCLE4-001 fix) fixture — iBATIS 2 <procedure> only mapper (rbac.xml 형식) -->
<sqlMap namespace="TestRbacDAO">
    <parameterMap id="paramMap" class="HashMap">
        <parameter property="systemCd" mode="IN" />
        <parameter property="userId" mode="IN" />
    </parameterMap>

    <procedure id="selectMenuList" parameterMap="paramMap" resultClass="HashMap">
        EXEC MDI.dbo.RBAC_MENU_LIST ?, ?
    </procedure>

    <procedure id="selectAuthList" parameterMap="paramMap" resultClass="HashMap">
        EXEC MDI.dbo.RBAC_AUTH_LIST_BASIC ?, ?
    </procedure>

    <procedure id="selectSystemList" parameterMap="paramMap" resultClass="HashMap">
        EXEC MDI.dbo.RBAC_SYSTEM_LIST ?
    </procedure>
</sqlMap>
