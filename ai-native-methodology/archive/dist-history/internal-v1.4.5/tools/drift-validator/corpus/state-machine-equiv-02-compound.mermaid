stateDiagram-v2
    [*] --> draft
    draft --> validating: SUBMIT

    state validating {
        [*] --> checkingFields
        checkingFields --> verifyingPolicy: fields ok
        verifyingPolicy --> rejected: policy fail
        verifyingPolicy --> readyToApprove: policy ok
    }

    validating --> approved: PASS
    validating --> draft: REJECT
    approved --> published: PUBLISH
    published --> [*]
