{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-native-methodology/schemas/a11y-spec.schema.json",
  "title": "A11y Spec (axe-core JSON 호환 + WCAG 2.1+2.2 ratchet)",
  "description": "Deliverable #10 (v1.4 신설). 정적 분석 가능 a11y 검증. axe-core 진짜 실행 의무 (no-simulation 정책). ADR-001 §명시적 제외 갱신 (정적 NFR 포함) + ADR-FE-005 §2.2.2 (WCAG 2.1-AA baseline + 2.2-AA ratchet) + ADR-010 (baseline+ratchet) + ADR-009 §2.2.1 (axe_core_real enum) 정합.",
  "x-spec-source": {
    "axe_core": "https://github.com/dequelabs/axe-core/blob/develop/doc/API.md",
    "wcag_2_1": "https://www.w3.org/TR/WCAG21/",
    "wcag_2_2": "https://www.w3.org/TR/WCAG22/",
    "wai_aria_1_2": "https://www.w3.org/TR/wai-aria-1.2/"
  },
  "type": "object",
  "required": ["meta", "scope", "violations", "summary"],
  "properties": {
    "meta": { "$ref": "./meta-confidence.schema.json" },
    "scope": {
      "type": "object",
      "required": ["baseline_wcag"],
      "properties": {
        "pages": {
          "type": "array",
          "items": { "type": "string", "pattern": "^PAGE-[A-Z0-9_-]+-\\d+$" }
        },
        "components": {
          "type": "array",
          "items": { "type": "string", "pattern": "^CMP-[A-Z0-9_-]+$" }
        },
        "stories": {
          "type": "array",
          "description": "Storybook CSF v3 story id (선택).",
          "items": { "type": "string" }
        },
        "baseline_wcag": {
          "type": "string",
          "enum": ["2.1-AA", "2.2-AA"],
          "default": "2.1-AA",
          "description": "★ ADR-FE-005 §2.2.2 baseline. fail 시 critical (★ ADR-010 baseline 정합)."
        },
        "ratchet_wcag": {
          "type": "string",
          "enum": ["2.1-AA", "2.1-AAA", "2.2-AA", "2.2-AAA"],
          "default": "2.2-AA",
          "description": "★ ADR-010 ratchet 격상 목표. fail 시 권장 (block ❌)."
        }
      }
    },
    "violations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "impact", "wcag_level"],
        "properties": {
          "id": {
            "type": "string",
            "description": "axe-core rule id (예: 'color-contrast', 'image-alt', 'aria-allowed-attr')."
          },
          "impact": {
            "type": "string",
            "enum": ["minor", "moderate", "serious", "critical"],
            "description": "axe-core impact level."
          },
          "wcag_criterion": {
            "type": "string",
            "description": "WCAG 성공 기준 ID (예: 'SC 1.4.3', 'SC 2.4.7'). axe-core tag 매핑."
          },
          "wcag_level": {
            "type": "string",
            "enum": ["2.1-A", "2.1-AA", "2.1-AAA", "2.2-A", "2.2-AA", "2.2-AAA"],
            "description": "WCAG version + level. baseline 2.1-AA / ratchet 2.2-AA 정합."
          },
          "wai_aria_role": {
            "type": "string",
            "description": "관련 WAI-ARIA 1.2 role (선택)."
          },
          "page_id": { "type": "string", "pattern": "^PAGE-[A-Z0-9_-]+-\\d+$" },
          "component_id": { "type": "string", "pattern": "^CMP-[A-Z0-9_-]+$" },
          "nodes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "target": {
                  "oneOf": [
                    {"type": "string"},
                    {"type": "array", "items": {"type": "string"}}
                  ],
                  "description": "CSS selector 문자열 또는 (iframe/shadow DOM) 문자열 배열."
                },
                "html": {"type": "string"},
                "failure_summary": {"type": "string"}
              }
            }
          },
          "help_url": {
            "type": "string",
            "format": "uri",
            "description": "axe-core help URL."
          },
          "source_file": {"type": "string"},
          "blocks_baseline": {
            "type": "boolean",
            "description": "★ baseline_wcag 위반 여부. true 시 critical (build block 권장)."
          },
          "blocks_ratchet": {
            "type": "boolean",
            "description": "ratchet_wcag 위반 여부. true 시 권장 (★ block ❌)."
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total_violations", "baseline_pass", "captured_by"],
      "properties": {
        "total_violations": {"type": "integer", "minimum": 0},
        "per_impact": {
          "type": "object",
          "properties": {
            "minor": {"type": "integer", "minimum": 0},
            "moderate": {"type": "integer", "minimum": 0},
            "serious": {"type": "integer", "minimum": 0},
            "critical": {"type": "integer", "minimum": 0}
          }
        },
        "per_wcag_level": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        },
        "baseline_pass": {
          "type": "boolean",
          "description": "★ baseline_wcag (2.1-AA) 통과 여부. ADR-010 정합 — false 시 build block."
        },
        "ratchet_pass": {
          "type": "boolean",
          "description": "ratchet_wcag (2.2-AA) 통과 여부. ADR-010 정합 — false 시 권장 (block ❌)."
        },
        "captured_by": {
          "type": "string",
          "enum": ["axe_core_real", "pa11y_real", "lighthouse_a11y_real", "simulation"],
          "description": "★ no-simulation 정책 (ADR-009 §2.2.1). simulation 시 -5%p 패널티 + simulation_reason 의무."
        },
        "captured_by_version": {
          "type": "string",
          "description": "도구 버전 (예: 'axe-core/4.10.0')."
        },
        "stdout_path": {"type": "string"},
        "duration_ms": {"type": "integer", "minimum": 0},
        "reproduction_command": {"type": "string"},
        "result_hash": {"type": "string"},
        "simulation_reason": {"type": "string"}
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "captured_by": {
                "enum": ["axe_core_real", "pa11y_real", "lighthouse_a11y_real"]
              }
            }
          },
          "then": {
            "required": ["captured_by_version", "stdout_path", "duration_ms", "reproduction_command"]
          }
        },
        {
          "if": {
            "properties": { "captured_by": {"const": "simulation"} }
          },
          "then": {
            "required": ["simulation_reason"]
          }
        }
      ]
    },
    "cross_links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from_violation", "to_artifact", "to_id", "link_type"],
        "properties": {
          "from_violation": {"type": "string"},
          "to_artifact": {
            "type": "string",
            "enum": ["ui-spec", "state-map", "visual-manifest", "antipatterns"]
          },
          "to_id": {"type": "string"},
          "link_type": {
            "type": "string",
            "enum": ["validates", "inline_in", "registers_as_antipattern"]
          }
        }
      }
    }
  }
}
