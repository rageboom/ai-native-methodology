{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '[ai-native-methodology] Plugin loaded. Read CLAUDE.md for the 23 policies + 4원칙 + ★★★ no-simulation. Stage = analysis (v1.4.x default). See methodology-spec/lifecycle-contract.md for SDLC stage interfaces.'",
            "statusMessage": "Loading AI-Native methodology context..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/tools/drift-validator/src/cli.js .aimd/output 2>&1 || true",
            "statusMessage": "Validating dual-rendering drift..."
          }
        ]
      }
    ]
  }
}
