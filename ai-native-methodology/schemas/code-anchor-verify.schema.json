{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-native-methodology/schemas/code-anchor-verify.schema.json",
  "title": "code-anchor-verify.json — codegraph ast_symbol 역방향 검증 (artifact→code / reference-lens / NOT gate-injected)",
  "description": "★ codegraph wiring STEP 4 (DEC-2026-06-03-codegraph-deliverable-wiring §5 STEP 4). 산출물 ast_symbol 앵커(provenance) ∖ codegraph 심볼 인덱스 = stale/dangling anchor ('산출물 앵커有 / 코드 심볼無'). STEP 1~3 coverage-hole 의 역방향. code-pointer-validator 가 못 하는 symbol 실재 검증. ★ trust: reference-lens / 비차단(severity low|medium ceiling) / 결정적 gate inject ❌. informational_notes(codegraph 사각=onlyArch 동형)는 severity 필드 구조적 부재 → finding 채널 진입 불가.",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "target", "stack", "codegraph", "anchor_verify", "findings"],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "generated_by", "do_not_edit_manually", "reference_lens", "trust_note", "severity_ceiling"],
      "properties": {
        "schema": { "const": "code-anchor-verify.schema.json" },
        "generated_by": { "const": "codegraph-coverage --verify-anchors" },
        "do_not_edit_manually": { "const": true },
        "reference_lens": { "const": true },
        "trust_note": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "severity_ceiling": {
          "type": "array",
          "items": { "enum": ["low", "medium"] },
          "description": "★ stale-anchor 은 low|medium 만 (상위 차단등급 절대 ❌ / findings-aggregator gate leak 차단)."
        }
      }
    },
    "target": { "type": "string" },
    "ref_sources": { "type": "array", "items": { "type": "string" } },
    "stack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language", "backend_known"],
      "properties": {
        "language": { "type": "string" },
        "backend_known": { "type": "boolean" },
        "orm": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ibatis2": { "type": "boolean" },
            "mybatis3": { "type": "boolean" },
            "jpa": { "type": "boolean" },
            "prisma": { "type": "boolean" }
          }
        },
        "signals": { "type": "string" }
      }
    },
    "codegraph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available", "db_path", "freshness"],
      "properties": {
        "available": { "type": "boolean" },
        "db_path": { "type": "string" },
        "reason": { "type": ["string", "null"] },
        "freshness": {
          "type": "object",
          "additionalProperties": false,
          "required": ["available", "stale"],
          "properties": {
            "available": { "type": "boolean" },
            "stale": { "type": "boolean" },
            "reason": { "type": "string" },
            "indexed_at": { "type": "string" },
            "newest_source_mtime": { "type": ["string", "null"] },
            "stale_count": { "type": "integer", "minimum": 0 },
            "stale_sample": { "type": "array", "items": { "type": "string" } },
            "capped": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "anchor_verify": {
      "type": "object",
      "additionalProperties": false,
      "description": "역방향 검증 결과. state=unverified = ast_symbol 앵커 부재(검증 대상 0 / false-health 회피). state=verified = 실 검증 수행.",
      "required": ["state", "total", "live", "stale", "informational"],
      "properties": {
        "state": { "enum": ["verified", "unverified"] },
        "reason": { "type": "string", "description": "state=unverified 일 때 사유." },
        "indexed_kinds": { "type": "array", "items": { "type": "string" } },
        "symbol_index_size": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0, "description": "수집된 ast_symbol 앵커 수 (검증 분모)." },
        "live": { "type": "integer", "minimum": 0, "description": "codegraph 심볼에 실재 확인 (함수단위 추적성 corroborated)." },
        "stale": { "type": "integer", "minimum": 0, "description": "파일 인덱싱됨 + 심볼 부재 = dangling (finding 채널)." },
        "informational": { "type": "integer", "minimum": 0, "description": "앵커 file 이 codegraph 미인덱스 = codegraph 사각 (부재≠stale / finding 채널 진입 ❌)." },
        "freshness_caveat": { "type": "string" },
        "live_anchors": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["symbol", "artifact"],
            "properties": {
              "symbol": { "type": "string" },
              "artifact": { "type": "string" },
              "file": { "type": ["string", "null"] }
            }
          }
        },
        "stale_anchors": {
          "type": "array",
          "description": "산출물 앵커인데 codegraph 인덱싱된 파일에 심볼 부재 = stale (안전 방향 / finding 채널 진입).",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["symbol", "artifact"],
            "properties": {
              "symbol": { "type": "string" },
              "normalized": { "type": "string" },
              "artifact": { "type": "string" },
              "file": { "type": ["string", "null"] }
            }
          }
        },
        "informational_notes": {
          "type": "array",
          "description": "★ 앵커 file 이 codegraph 미인덱스 = codegraph 사각(iBATIS2 sql/xml·동적·미지원 언어·freshness stale·anchor path 부재). NOT a defect / 부재≠stale. ★ ★ severity 필드 구조적 부재 (additionalProperties:false) — finding/coverage-hole 채널 진입 절대 ❌ (Senior / check37 가드 / STEP 3 informational_notes 동형).",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["symbol", "artifact", "reason"],
            "properties": {
              "symbol": { "type": "string" },
              "artifact": { "type": "string" },
              "file": { "type": ["string", "null"] },
              "reason": { "type": "string" }
            }
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "axis", "severity", "message"],
        "properties": {
          "id": { "type": "string", "pattern": "^F-CGANCH-[0-9]{3}$" },
          "axis": { "const": "anchor" },
          "severity": { "enum": ["low", "medium"] },
          "message": { "type": "string" },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "code_graph_ref": {
            "type": "object",
            "additionalProperties": false,
            "description": "stale 앵커가 주장한 코드 좌표 (codegraph 가 해소 못 한 ast_symbol). promote 시 finding-system code_graph_ref 로 이식.",
            "required": ["kind"],
            "properties": {
              "kind": { "type": "string" },
              "symbol": { "type": "string" },
              "file": { "type": "string" },
              "line": { "type": "integer", "minimum": 0 },
              "node_id": { "type": "string" },
              "db_path": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
