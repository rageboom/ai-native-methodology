{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-native-methodology/schemas/meta-confidence.schema.json",
  "title": "신뢰도 메타데이터 (Confidence Metadata)",
  "description": "모든 산출물에 필수로 포함되는 메타데이터. 출처와 신뢰도를 명시함.",
  "type": "object",
  "required": ["generated_at", "confidence", "inputs_used"],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "산출물 생성 시각 (ISO 8601)"
    },
    "source_commit_sha": {
      "type": "string",
      "description": "분석 대상 레포의 git commit SHA"
    },
    "methodology_version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+(\\.\\d+)?$",
      "description": "본 산출물을 생성한 방법론 버전 (예: v1.1.0)",
      "examples": ["v1.1.0"]
    },
    "inputs_used": {
      "type": "array",
      "description": "분석에 사용된 입력 출처 목록. ADR-003 §6.3의 modifier 항목과 정합.",
      "items": {
        "type": "string",
        "enum": [
          "source_code",
          "erd",
          "orm",
          "operational_db",
          "planning_docs",
          "design_specs",
          "config_files",
          "test_code",
          "documentation",
          "domain_context_md",
          "postman_or_api_test",
          "diagrams_other",
          "characterization"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 0.98,
      "description": "전체 산출물의 신뢰도 (0.0~0.98). cap 0.98 (100% 신뢰는 불가능). ADR-003 §6 산정 공식 v1 참조."
    },
    "confidence_breakdown": {
      "type": "object",
      "description": "산출물 내 영역별 신뢰도 (요소 수 가중 평균에 사용). ADR-003 §7 참조.",
      "additionalProperties": {
        "type": "object",
        "required": ["confidence"],
        "properties": {
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 0.98,
            "description": "이 영역의 신뢰도"
          },
          "element_count": {
            "type": "integer",
            "minimum": 0,
            "description": "이 영역의 추출 항목 수 (가중 평균에 사용)"
          },
          "extraction_method": {
            "type": "string",
            "enum": ["deterministic", "pattern_matching", "llm_with_grounding", "llm_code_only"],
            "description": "추출 방법. ADR-003 §8 표 참조."
          }
        }
      }
    },
    "formula_version": {
      "type": "string",
      "enum": ["v1"],
      "default": "v1",
      "description": "신뢰도 산정 공식 버전. ADR-003 §6 참조. 공식 변경 시 마이그레이션 추적용."
    },
    "applied_modifiers": {
      "type": "array",
      "description": "적용된 가산점 항목들 (어떤 입력이 어떤 가산점을 줬는지). ADR-003 §6.3 참조.",
      "items": {
        "type": "object",
        "required": ["name", "value"],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "erd",
              "orm_full",
              "orm_partial",
              "operational_db",
              "planning_docs",
              "design_specs",
              "config_files",
              "domain_context_md",
              "postman_or_api_test",
              "diagrams_other"
            ]
          },
          "value": {
            "type": "number",
            "description": "이 가산점의 값 (예: 0.10)"
          }
        }
      }
    },
    "applied_penalties": {
      "type": "array",
      "description": "적용된 페널티 항목들. ADR-003 §6.4 참조.",
      "items": {
        "type": "object",
        "required": ["name", "value"],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "source_drift",
              "no_orm",
              "monorepo_flat_analysis",
              "legacy_unmaintained",
              "zero_test_coverage"
            ]
          },
          "value": {
            "type": "number",
            "description": "이 페널티의 값 (음수, 예: -0.05)"
          }
        }
      }
    },
    "cap_applied": {
      "type": "boolean",
      "default": false,
      "description": "산정 결과가 0.98 cap에 의해 제한되었는지 여부 (raw가 0.98 초과 시 true)"
    },
    "manual_override": {
      "type": "boolean",
      "default": false,
      "description": "사용자가 자동 산정값을 수동으로 변경했는지 여부. true면 review_status 필수."
    },
    "human_review_required": {
      "type": "array",
      "description": "사람 검토가 필요한 항목 목록 (ID + 이유)",
      "items": {
        "type": "object",
        "required": ["item_id", "reason"],
        "properties": {
          "item_id": {
            "type": "string",
            "description": "검토 대상 ID (예: BR-ORDER-007)"
          },
          "reason": {
            "type": "string",
            "description": "검토 필요 이유"
          },
          "reviewer_role": {
            "type": "string",
            "enum": ["domain_expert", "tech_lead", "designer", "planner", "any"],
            "description": "권장 검토자 역할"
          }
        }
      }
    },
    "llm_calls": {
      "type": "integer",
      "minimum": 0,
      "description": "본 산출물 생성에 사용된 LLM 호출 횟수"
    },
    "llm_cost_usd": {
      "type": "number",
      "minimum": 0,
      "description": "본 산출물 생성에 든 LLM 비용 (USD)"
    },
    "warnings": {
      "type": "array",
      "description": "분석 중 발생한 경고 (출처 누락, 모호 케이스 등)",
      "items": {
        "type": "string"
      }
    }
  }
}
