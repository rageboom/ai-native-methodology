{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-native-methodology/schemas/static-security-spec.schema.json",
  "title": "Static Security Spec (정적 분석 가능 보안 — XSS / CSRF / CSP / SRI / cookie)",
  "description": "Deliverable #12 (v1.4 신설). 정적 분석 가능 보안 검증. Semgrep / ESLint security plugin 진짜 실행 의무 (no-simulation 정책). ★ 운영 NFR ❌ — runtime check 의무 카테고리 별도 표기. ADR-001 §명시적 제외 갱신 (정적 NFR 포함) + OWASP Top 10 정합.",
  "x-spec-source": {
    "owasp_top10": "https://owasp.org/Top10/",
    "csp_level3": "https://www.w3.org/TR/CSP3/",
    "sri": "https://www.w3.org/TR/SRI/",
    "trusted_types": "https://w3c.github.io/trusted-types/",
    "cwe": "https://cwe.mitre.org/"
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "scope", "findings", "summary"],
  "properties": {
    "meta": { "$ref": "./meta-confidence.schema.json" },
    "scope": {
      "type": "object",
      "properties": {
        "pages": { "type": "array", "items": {"type": "string"} },
        "components": { "type": "array", "items": {"type": "string"} },
        "categories_checked": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "xss_dom_based",
              "xss_reflected",
              "xss_stored",
              "csrf_token_missing",
              "csrf_samesite_missing",
              "csp_missing",
              "csp_unsafe_inline",
              "csp_unsafe_eval",
              "csp_wildcard_source",
              "sri_missing",
              "trusted_types_missing",
              "innerHTML_dangerous_use",
              "dangerouslySetInnerHTML_react",
              "v_html_vue",
              "bypassSecurityTrustHtml_angular",
              "cookie_missing_httponly",
              "cookie_missing_secure",
              "cookie_missing_samesite",
              "cors_wildcard",
              "target_blank_noopener_missing",
              "javascript_url_in_href",
              "eval_usage",
              "function_constructor_usage",
              "open_redirect"
            ]
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category", "severity", "source_file"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^F-FE-SEC-\\d+$"
          },
          "category": {
            "type": "string",
            "description": "scope.categories_checked enum 값."
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "cwe_id": {
            "type": "string",
            "pattern": "^CWE-\\d+$",
            "description": "CWE ID (예: CWE-79 XSS)."
          },
          "owasp_top10": {
            "type": "string",
            "description": "OWASP Top 10 카테고리 (예: 'A03:2021-Injection')."
          },
          "source_file": {"type": "string"},
          "line": {"type": "integer", "minimum": 1},
          "source_snippet": {"type": "string"},
          "fix_suggestion": {"type": "string"},
          "page_id": {"type": "string"},
          "component_id": {"type": "string"},
          "runtime_check_required": {
            "type": "boolean",
            "description": "★ 정적 분석만으로 미흡 — runtime check 의무 표기. true 시 사용자 confirm 의무."
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total_findings", "captured_by"],
      "properties": {
        "total_findings": {"type": "integer", "minimum": 0},
        "per_severity": {
          "type": "object",
          "properties": {
            "critical": {"type": "integer", "minimum": 0},
            "high": {"type": "integer", "minimum": 0},
            "medium": {"type": "integer", "minimum": 0},
            "low": {"type": "integer", "minimum": 0}
          }
        },
        "per_category": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        },
        "captured_by": {
          "type": "string",
          "enum": [
            "semgrep_real",
            "eslint_security_real",
            "snyk_code_real",
            "codeql_real",
            "sonarjs_real",
            "simulation"
          ],
          "description": "★ no-simulation 정책. simulation 시 -5%p 패널티 + simulation_reason 의무."
        },
        "captured_by_version": {"type": "string"},
        "stdout_path": {"type": "string"},
        "duration_ms": {"type": "integer", "minimum": 0},
        "reproduction_command": {"type": "string"},
        "result_hash": {"type": "string"},
        "simulation_reason": {"type": "string"},
        "runtime_check_required_count": {
          "type": "integer",
          "minimum": 0,
          "description": "runtime_check_required=true 인 finding 개수. > 0 시 사용자 confirm 의무 표기 의무."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "captured_by": {
                "enum": [
                  "semgrep_real",
                  "eslint_security_real",
                  "snyk_code_real",
                  "codeql_real",
                  "sonarjs_real"
                ]
              }
            }
          },
          "then": {
            "required": ["captured_by_version", "stdout_path", "duration_ms", "reproduction_command"]
          }
        },
        {
          "if": {
            "properties": { "captured_by": {"const": "simulation"} }
          },
          "then": {
            "required": ["simulation_reason"]
          }
        }
      ]
    },
    "cross_links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from_finding", "to_artifact", "to_id", "link_type"],
        "properties": {
          "from_finding": {"type": "string"},
          "to_artifact": {
            "type": "string",
            "enum": ["ui-spec", "state-map", "visual-manifest", "antipatterns"]
          },
          "to_id": {"type": "string"},
          "link_type": {
            "type": "string",
            "enum": ["validates", "registers_as_antipattern", "blocks_baseline"]
          }
        }
      }
    }
  }
}
