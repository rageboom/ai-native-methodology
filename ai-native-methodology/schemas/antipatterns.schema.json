{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-native-methodology/schemas/antipatterns.schema.json",
  "title": "안티패턴 카탈로그 (Antipatterns)",
  "description": "재구현 시 회피해야 할 후보 목록. 비난 톤이 아닌 '회피 후보' 톤으로 작성.",
  "type": "object",
  "required": ["meta", "antipatterns"],
  "properties": {
    "meta": {
      "$ref": "./meta-confidence.schema.json"
    },
    "antipatterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category", "name", "severity"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^AP-[A-Z]+-\\d+$",
            "description": "안티패턴 ID (예: AP-DB-007, AP-ARCH-003)"
          },
          "category": {
            "type": "string",
            "enum": [
              "ARCH",
              "DB",
              "DOMAIN",
              "API",
              "FE",
              "CONFIG",
              "EXTERNAL",
              "SECURITY",
              "PERFORMANCE",
              "TESTABILITY",
              "MAINTAINABILITY"
            ],
            "description": "카테고리"
          },
          "name": {
            "type": "string",
            "description": "짧은 이름 (예: '비즈니스 정책이 SQL CASE에 박힘')"
          },
          "description": {
            "type": "string",
            "description": "상세 설명"
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "info"],
            "description": "심각도"
          },
          "why_avoid": {
            "type": "string",
            "description": "왜 회피해야 하는가 (재구현 관점)"
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["file"],
              "properties": {
                "file": {"type": "string"},
                "line": {"type": "integer"},
                "snippet": {"type": "string"},
                "context_note": {"type": "string"}
              }
            }
          },
          "occurrences": {
            "type": "integer",
            "minimum": 1,
            "description": "발견 횟수 (같은 패턴이 여러 곳에 있으면)"
          },
          "recommended_alternative": {
            "type": "string",
            "description": "권장 대안 (재구현 시 어떻게 바꿀지)"
          },
          "related_rules_to_extract": {
            "type": "array",
            "items": {"type": "string"},
            "description": "이 안티패턴 자리에서 추출되어야 하는 비즈니스 규칙 ID들"
          },
          "related_modules": {
            "type": "array",
            "items": {"type": "string"}
          },
          "detected_by": {
            "type": "string",
            "enum": ["static_analysis", "llm_inference", "pattern_match", "human_review"],
            "description": "감지 방식"
          },
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 0.98,
            "description": "이 안티패턴 검출의 신뢰도. cap 0.98 (ADR-003 §6.1)."
          },
          "human_review_status": {
            "type": "string",
            "enum": ["pending", "confirmed", "false_positive", "wont_fix"],
            "default": "pending"
          },
          "tags": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "description": "카테고리별 요약 통계",
      "properties": {
        "by_category": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "count": {"type": "integer"},
              "by_severity": {
                "type": "object",
                "additionalProperties": {"type": "integer"}
              }
            }
          }
        },
        "total_count": {"type": "integer"},
        "critical_count": {"type": "integer"}
      }
    },
    "checklist_file": {
      "type": "string",
      "description": "사람이 보기 쉬운 체크리스트 마크다운 파일 경로 (avoid-list.md)"
    }
  }
}
