{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-native-methodology/schemas/code-coverage-hole.schema.json",
  "title": "code-coverage-hole.json — codegraph code→artifact coverage-hole (reference-lens / NOT gate-injected)",
  "description": "codegraph wiring STEP 1 (DEC-2026-06-03-codegraph-deliverable-wiring §5). codegraph .codegraph/codegraph.db 의 코드 엔티티(route/method) 전수 ∖ 산출물 code-ref = '코드有 산출물無' coverage-hole. trust: reference-lens / 비차단(severity low|medium ceiling) / 결정적 gate inject ❌. severity enum 이 구조적으로 high·critical 을 배제 (gate leak 차단).",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "target", "active_axes", "stack", "codegraph", "coverage", "findings"],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "generated_by", "do_not_edit_manually", "reference_lens", "trust_note", "severity_ceiling"],
      "properties": {
        "schema": { "const": "code-coverage-hole.schema.json" },
        "generated_by": { "const": "codegraph-coverage" },
        "do_not_edit_manually": { "const": true },
        "reference_lens": { "const": true },
        "trust_note": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "severity_ceiling": {
          "type": "array",
          "items": { "enum": ["low", "medium"] },
          "description": "coverage-hole 은 low|medium 만 (high·critical 절대 ❌ / findings-aggregator gate leak 차단)."
        }
      }
    },
    "target": { "type": "string" },
    "active_axes": { "type": "array", "items": { "type": "string" } },
    "ref_sources": { "type": "array", "items": { "type": "string" } },
    "stack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language", "backend_known"],
      "properties": {
        "language": { "type": "string" },
        "backend_known": { "type": "boolean" },
        "orm": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ibatis2": { "type": "boolean" },
            "mybatis3": { "type": "boolean" },
            "jpa": { "type": "boolean" },
            "prisma": { "type": "boolean" }
          }
        },
        "signals": { "type": "string" }
      }
    },
    "codegraph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available", "db_path", "freshness"],
      "properties": {
        "available": { "type": "boolean" },
        "db_path": { "type": "string" },
        "reason": { "type": ["string", "null"] },
        "freshness": {
          "type": "object",
          "additionalProperties": false,
          "required": ["available", "stale"],
          "properties": {
            "available": { "type": "boolean" },
            "stale": { "type": "boolean" },
            "reason": { "type": "string" },
            "indexed_at": { "type": "string" },
            "newest_source_mtime": { "type": ["string", "null"] },
            "stale_count": { "type": "integer", "minimum": 0 },
            "stale_sample": { "type": "array", "items": { "type": "string" } },
            "capped": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["axes", "undetectable", "stats"],
      "properties": {
        "axes": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "route": { "$ref": "#/$defs/routeAxis" },
            "method": { "$ref": "#/$defs/methodAxis" },
            "module": { "$ref": "#/$defs/moduleAxis" }
          }
        },
        "undetectable": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["axis", "state", "reason"],
            "properties": {
              "axis": { "type": "string" },
              "state": { "enum": ["undetectable", "unverified"] },
              "reason": { "type": "string" }
            }
          }
        },
        "stats": {
          "type": "object",
          "additionalProperties": false,
          "required": ["route_total", "route_holes", "method_total", "method_holes", "undetectable_axes"],
          "properties": {
            "route_total": { "type": "integer", "minimum": 0 },
            "route_holes": { "type": "integer", "minimum": 0 },
            "method_total": { "type": "integer", "minimum": 0 },
            "method_holes": { "type": "integer", "minimum": 0 },
            "module_total": { "type": "integer", "minimum": 0 },
            "module_holes": { "type": "integer", "minimum": 0 },
            "module_informational": { "type": "integer", "minimum": 0 },
            "undetectable_axes": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "axis", "severity", "message"],
        "properties": {
          "id": { "type": "string", "pattern": "^F-CGCOV-[0-9]{3}$" },
          "axis": { "type": "string" },
          "severity": { "enum": ["low", "medium"] },
          "message": { "type": "string" },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "code_graph_ref": {
            "type": "object",
            "additionalProperties": false,
            "description": "v12.10.0 STEP 2 — coverage-hole 의 codegraph 코드 앵커 (auto-seed). finding-system.schema.json code_graph_ref 와 동형. promote 시 F-XXX ledger 로 그대로 이식.",
            "required": ["kind"],
            "properties": {
              "kind": { "type": "string" },
              "symbol": { "type": "string" },
              "file": { "type": "string" },
              "line": { "type": "integer", "minimum": 0 },
              "edge_kind": { "type": "string", "enum": ["contains", "imports", "calls", "references", "instantiates", "extends", "implements", "decorates"] },
              "node_id": { "type": "string" },
              "db_path": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "routeAxis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["detectable", "total", "covered", "holes"],
      "properties": {
        "detectable": { "type": "boolean" },
        "total": { "type": "integer", "minimum": 0 },
        "covered": { "type": "integer", "minimum": 0 },
        "excluded_count": { "type": "integer", "minimum": 0 },
        "dynamic_count": { "type": "integer", "minimum": 0 },
        "holes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "normalized_path", "file"],
            "properties": {
              "verb": { "type": ["string", "null"] },
              "path": { "type": "string" },
              "normalized_path": { "type": "string" },
              "file": { "type": "string" }
            }
          }
        },
        "excluded_routes": { "$ref": "#/$defs/routeRefList" },
        "dynamic_routes": { "$ref": "#/$defs/routeRefList" }
      }
    },
    "routeRefList": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["route"],
        "properties": {
          "route": { "type": "string" },
          "file": { "type": "string" }
        }
      }
    },
    "methodAxis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["detectable", "total", "covered", "holes"],
      "properties": {
        "detectable": { "type": "boolean" },
        "total": { "type": "integer", "minimum": 0 },
        "covered": { "type": "integer", "minimum": 0 },
        "filtered": { "type": "integer", "minimum": 0 },
        "holes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["symbol", "file"],
            "properties": {
              "symbol": { "type": "string" },
              "name": { "type": "string" },
              "file": { "type": "string" }
            }
          }
        }
      }
    },
    "moduleAxis": {
      "type": "object",
      "additionalProperties": false,
      "description": "v12.11.0 STEP 3 — module dependency coverage-hole (codegraph cross-file edge rollup ∖ architecture.json dependencies[]). '대치' 아니라 결정론 corroboration lens. holes = codegraph有/arch無(LLM 놓침). informational_notes = arch有/codegraph無(codegraph 사각 / NOT a defect / severity 부재).",
      "required": ["detectable", "total", "covered", "holes"],
      "properties": {
        "detectable": { "type": "boolean" },
        "total": { "type": "integer", "minimum": 0, "description": "codegraph 결정론 module→module 의존 수 (coverage 분모)." },
        "covered": { "type": "integer", "minimum": 0, "description": "arch.json dependencies[] 가 이미 문서화 (corroborated)." },
        "module_count": { "type": "integer", "minimum": 0 },
        "rollup_stats": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cross_file": { "type": "integer", "minimum": 0 },
            "test_skipped": { "type": "integer", "minimum": 0 },
            "unmapped": { "type": "integer", "minimum": 0 },
            "intra_module": { "type": "integer", "minimum": 0 }
          }
        },
        "holes": {
          "type": "array",
          "description": "codegraph 결정론 의존인데 arch.json 미문서화 = coverage-hole (안전 방향 / finding 채널 진입).",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from", "to", "weight"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "weight": { "type": "integer", "minimum": 1 },
              "edge_kinds": { "type": "array", "items": { "type": "string" } },
              "sample_file": { "type": "string" }
            }
          }
        },
        "informational_notes": {
          "type": "array",
          "description": "onlyArch (arch.json有 / codegraph無 = codegraph 사각: 런타임 DI/decorator/config 와이어링·iBATIS2·동적). NOT a defect / 부재≠거짓. severity 필드 구조적 부재 (additionalProperties:false) — finding/coverage-hole 채널 진입 절대 ❌ (Senior must-fix#3 / check36 가드).",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from", "to"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "type": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
