{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-native-methodology/schemas/impl-spec.schema.json",
  "title": "Impl Spec (chain implement / 구현 명세 + 실 impl 코드 메타)",
  "description": "v2.0 chain harness 의 implement stage 산출물 (i-strict 정통). test-spec 기반 실 impl 코드 자동 생성 (GREEN 의무 / 100% test pass). ★ ★ ★ chain implement single source-of-truth = 본 impl-spec.json (B7 14차 retract 차단). 실 코드 = 산출물 ❌ (commit_hash 만 보존). DEC-2026-05-06-v2.0-i-strict-채택 정합. ★ v11.0.0 MAJOR 확장 (DEC-2026-05-26-be-fe-산출물-분리 §3) — modules[].layer enum + stack enum 신설 (BE/FE 분기 본격 / additive optional / backward-compat).",
  "type": "object",
  "required": ["meta", "derivation_source", "modules", "test_pass_evidence", "coverage", "human_review"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "$ref": "./meta-confidence.schema.json"
    },
    "derivation_source": {
      "type": "object",
      "required": ["test_spec_path", "behavior_spec_path"],
      "additionalProperties": false,
      "properties": {
        "test_spec_path": {"type": "string"},
        "behavior_spec_path": {"type": "string"}
      }
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "tc_refs", "bhv_refs", "framework", "source_files", "commit_hash"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^IMPL-[A-Z0-9_-]+-[0-9]{3}$"
          },
          "tc_refs": {
            "type": "array",
            "items": {"type": "string", "pattern": "^TC-[A-Z0-9_-]+-[0-9]{3}$"},
            "minItems": 1,
            "description": "★ chain 3 backward link 의무"
          },
          "bhv_refs": {
            "type": "array",
            "items": {"type": "string", "pattern": "^BHV-[A-Z0-9_-]+-[0-9]{3}$"},
            "minItems": 1,
            "description": "★ chain 2 backward link"
          },
          "framework": {
            "type": "string",
            "description": "★ B3 open enum — phase-1-inventory stack 정합 (예: spring-boot-3 / nestjs-10 / express-4 / fastapi-0.110 / rails-7 / react-18). framework = stack+version 결합 형태 (예: spring-boot-3). stack base name 만 분리 격납은 본 schema 의 `stack` field 안."
          },
          "layer": {
            "type": "string",
            "enum": ["be", "fe", "db", "e2e", "infra"],
            "description": "★ v11.0.0 신설 (DEC-2026-05-26-be-fe-산출물-분리 §3 정합). impl-spec 안 layer 본격 분기 — be (Spring/NestJS/FastAPI/Rails 등) / fe (React/Vue/Svelte/Solid 등) / db (migration / DDL 등) / e2e (Playwright 등) / infra (Terraform / Docker 등). additive optional (backward-compat / 기존 PoC layer 부재 OK)."
          },
          "stack": {
            "type": "string",
            "enum": [
              "spring-boot",
              "nestjs",
              "express",
              "fastapi",
              "flask",
              "rails",
              "phoenix",
              "go-gin",
              "go-fiber",
              "react",
              "vue",
              "svelte",
              "solid",
              "angular",
              "next-js",
              "nuxt",
              "remix",
              "postgresql",
              "mysql",
              "sqlite",
              "mongodb",
              "playwright",
              "cypress",
              "terraform",
              "docker"
            ],
            "description": "★ v11.0.0 신설 (DEC-2026-05-26-be-fe-산출물-분리 §3 정합). stack base name (version 제외). framework field 안 stack+version 결합과 별 axis. additive optional. 본 enum = 사내 가장 빈도 24종 (BE 9 + FE 8 + DB 4 + e2e 2 + infra 1). 사내 stack 추가 시 enum 확장 필요 — drift attractor 위험 / open enum 전환은 v11.x carry."
          },
          "source_files": {
            "type": "array",
            "items": {"type": "string"},
            "minItems": 1,
            "description": "실 impl 코드 파일 경로 (★ commit_hash 로 결정성 보장)"
          },
          "commit_hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{40}$",
            "description": "★ B7 14차 retract 차단 — 실 코드 = 산출물 ❌ / commit_hash 만 본 산출물에 보존 / git 으로 결정적 trace"
          },
          "source_evidence": {
            "type": "string",
            "description": "★ no-simulation — 실 코드 excerpt (≤ 500 char) / commit_hash 의 source_files 와 sha 일치 의무"
          },
          "code_pointers": {
            "type": "array",
            "description": "★ operation.md 결정 3 + P2 — artifact ↔ code anchor. source_files 의 strict_path 평탄화 보완 / glob·ast_symbol·doc_link 등 비단조 anchor 추가 표현. graph-synthesizer 가 평탄화 / code-pointer-validator 가 검증.",
            "items": {"$ref": "./code-pointer.schema.json"}
          },
          "code_pointers_na": {
            "type": "boolean",
            "default": false,
            "description": "★ 명시적 N/A 마커 (operation.md 결정 3)."
          }
        }
      }
    },
    "test_pass_evidence": {
      "type": "object",
      "description": "★ ★ ★ chain 5 GREEN 의무 — 진짜 runner 100% pass 입증. 5종 물증 7 필드 (B5 정규화)",
      "required": ["test_runner_version", "test_runner_stdout_path", "invocation_timestamp", "duration_ms", "pass_count", "fail_count", "skip_count", "reproduction_command", "result_hash", "report_format"],
      "additionalProperties": false,
      "properties": {
        "test_runner_version": {"type": "string"},
        "test_runner_stdout_path": {"type": "string"},
        "test_runner_stderr_path": {"type": "string", "description": "★ B5 optional"},
        "invocation_timestamp": {"type": "string", "format": "date-time"},
        "duration_ms": {"type": "integer", "minimum": 0},
        "pass_count": {"type": "integer", "minimum": 0},
        "fail_count": {"type": "integer", "const": 0, "description": "★ chain 5 GREEN 의무 — 0 만 허용"},
        "skip_count": {"type": "integer", "minimum": 0},
        "reproduction_command": {
          "oneOf": [
            {"type": "string"},
            {"type": "array", "items": {"type": "string"}, "minItems": 1}
          ]
        },
        "result_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "report_format": {
          "type": "string",
          "enum": ["sarif_2_1_0", "junit_xml", "jest_json", "pytest_json", "vitest_json", "lcov", "cobertura_xml", "jacoco_xml"]
        },
        "coverage_report_path": {"type": "string", "description": "LCOV / JaCoCo / Cobertura 경로"},
        "linter_output_path": {"type": "string", "description": "★ static-runner 6종 결과 (Semgrep / PMD / SpotBugs / etc.)"},
        "flaky_retries_count": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "★ ★ ADR-CHAIN-004 §5 — Playwright per-test cap 2 정합. 실제 retry 발생 횟수 누적 (chain 5 GREEN 의무 = fail_count 0 이지만 retry 발생 시 본 필드로 trace)"
        }
      }
    },
    "coverage": {
      "type": "object",
      "required": ["link_coverage", "test_pass_rate"],
      "additionalProperties": false,
      "properties": {
        "link_coverage": {
          "type": "object",
          "required": ["by_acceptance_criteria", "threshold"],
          "additionalProperties": false,
          "properties": {
            "by_acceptance_criteria": {"type": "number", "minimum": 0, "maximum": 1},
            "by_business_rule": {"type": "number", "minimum": 0, "maximum": 1},
            "by_use_case": {"type": "number", "minimum": 0, "maximum": 1},
            "threshold": {"type": "number", "minimum": 0.85, "maximum": 0.95},
            "severity_floor": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "critical": {"type": "number", "const": 1.0},
                "high": {"type": "number", "minimum": 0.95, "maximum": 1.0},
                "medium": {"type": "number", "minimum": 0.90, "maximum": 1.0},
                "low": {"type": "number", "minimum": 0.85, "maximum": 1.0}
              }
            }
          }
        },
        "test_pass_rate": {
          "type": "number",
          "const": 1.0,
          "description": "★ chain 5 GREEN 의무 (1.0 fixed)"
        },
        "line_coverage": {"type": "number", "minimum": 0, "maximum": 1},
        "branch_coverage": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "human_review": {
      "type": "object",
      "description": "★ Blocker 2 해결안 — 70~80% 한계 schema 수용 (master plan §J.2 옵션 A 정합)",
      "required": ["gate_4_intervention_pct"],
      "additionalProperties": false,
      "properties": {
        "gate_4_intervention_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 0.30,
          "description": "★ ★ ★ 70~80% 한계 명시 — 사용자 검토 ≤ 30% (정량 boundary)"
        },
        "intervention_log": {
          "type": "array",
          "items": {"type": "string"},
          "description": "사용자 결단 trace (gate #4 go/stop 결단 이유)"
        }
      }
    },
    "chain_attempt": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "attempt_n": {"type": "integer", "minimum": 1},
        "retry_cap": {"type": "integer", "minimum": 1, "default": 3},
        "revisit_count": {"type": "integer", "minimum": 0, "default": 0}
      }
    },
    "real_integration_axis": {
      "type": "object",
      "description": "★ v8.8.0 Tier 1.2 — chain 5 GREEN 의 진정성 측정 axis (informational / v8.9+ mandatory carry). chain 4 가 unit-only mock fixture 통과인지 실 외부 의존성 통합 통과인지 구분. 본 field 부재 시 unknown 처리 / breaking 0.",
      "additionalProperties": false,
      "properties": {
        "prisma_client_injected": {
          "type": "boolean",
          "description": "Prisma client (또는 동등 ORM client) 가 실 주입됐는지 (cycle-7 dogfood: car.service.ts:63 `prisma: unknown` = false / cycle-3 car.service.ts: constructor(prisma: PrismaService) = true)"
        },
        "e2e_supertest_count": {
          "type": "integer",
          "minimum": 0,
          "description": "supertest e2e test 개수 (NestApp bootstrap 통합 / cycle-3 F-CYCLE3-004 carry 정합 metric)"
        },
        "real_db_fixture_loaded": {
          "type": "boolean",
          "description": "실 DB (SQLite / MSSQL / PostgreSQL) migrate + seed 통과 여부"
        },
        "real_integration_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "0~1 normalized integration completeness (3 boolean + supertest count weighted)"
        },
        "evidence_paths": {
          "type": "array",
          "items": {"type": "string"},
          "description": "real_integration evidence file paths (jsonl / log)"
        }
      }
    },
    "mock_detect": {
      "type": "object",
      "description": "★ v8.8.0 Tier 1.1 — mock_implementation_ratio detect 결과 (experimental opt-in). test-impl-pass-validator --detect-mock-impl 의 산출.",
      "additionalProperties": false,
      "properties": {
        "mode": {"type": "string", "enum": ["off", "experimental", "enforce"]},
        "mock_implementation_ratio": {"type": "number", "minimum": 0, "maximum": 1},
        "file_mock_ratio": {"type": "number", "minimum": 0, "maximum": 1},
        "score_threshold": {"type": "number"},
        "file_threshold": {"type": "number"},
        "files_with_indicators": {"type": "integer", "minimum": 0},
        "files_scanned": {"type": "integer", "minimum": 0},
        "mock_locations_total": {"type": "integer", "minimum": 0},
        "exceeded": {"type": "boolean"}
      }
    }
  }
}
