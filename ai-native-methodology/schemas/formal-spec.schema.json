{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-native-methodology/schemas/formal-spec.schema.json",
  "title": "Formal Spec (형식 명세)",
  "description": "Phase 4.5 산출물. 자연어 빈약성 (44%) 보완 + AI 코드 생성 정확도 (60% → 90%) 향상. v1.2.0 신설 (묶음 L). PoC #02 C-Sprint 1+1.5+2 정량 입증. ADR-008 (이중 렌더링) + ADR-009 (다이어그램 신뢰 모델) 정합.",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "state_machines", "sequences", "decision_tables", "invariants", "property_tests"],
  "properties": {
    "meta": {
      "$ref": "./meta-confidence.schema.json"
    },
    "state_machines": {
      "type": "array",
      "description": "Aggregate Root 별 상태/전이/이벤트/가드. XState 호환.",
      "items": {
        "type": "object",
        "required": ["aggregate_root", "id", "initial", "states"],
        "properties": {
          "aggregate_root": {
            "type": "string",
            "description": "Aggregate Root 이름 (domain.json 정합)."
          },
          "id": {
            "type": "string",
            "description": "FSM 식별자. 예: User-Account, User-Following."
          },
          "initial": {
            "type": "string",
            "description": "초기 상태."
          },
          "states": {
            "type": "object",
            "description": "상태 객체. 키: 상태명. 값: { on: { 이벤트: 다음상태 또는 객체 } }",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "on": {
                  "type": "object",
                  "additionalProperties": {
                    "oneOf": [
                      {"type": "string"},
                      {
                        "type": "object",
                        "properties": {
                          "target": {"type": "string"},
                          "guard": {"type": "string"},
                          "actions": {"type": "array", "items": {"type": "string"}}
                        }
                      }
                    ]
                  }
                },
                "type": {"type": "string", "enum": ["final", "history", "compound"]}
              }
            }
          },
          "rendered_mermaid_path": {
            "type": "string",
            "description": "이중 렌더링 정합 — 사람 눈 .mermaid 파일 경로."
          }
        }
      }
    },
    "sequences": {
      "type": "array",
      "description": "Use Case 오케스트레이션. actor / message / sync / guard 구조.",
      "items": {
        "type": "object",
        "required": ["uc_id", "actors", "messages"],
        "properties": {
          "uc_id": {
            "type": "string",
            "pattern": "^UC-[A-Z0-9_-]+-[0-9]{3}$",
            "description": "Use Case ID (★ v2.0 통일 / id-conventions canonical / 예: UC-USER-001, UC-USER-003 / 기존 이름 형식 (UC-USER-SIGNUP) = sub-plan-6 migration carry)."
          },
          "actors": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "type"],
              "properties": {
                "id": {"type": "string"},
                "type": {"type": "string", "enum": ["user", "controller", "service", "domain", "repository", "external", "system"]}
              }
            }
          },
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["from", "to", "label"],
              "properties": {
                "from": {"type": "string"},
                "to": {"type": "string"},
                "label": {"type": "string"},
                "sync": {"type": "string", "enum": ["sync", "async", "return"]},
                "guard": {"type": "string"}
              }
            }
          },
          "rendered_mermaid_path": {
            "type": "string"
          }
        }
      }
    },
    "decision_tables": {
      "type": "array",
      "description": "BR 의사결정 테이블. 자연어 빈약성 9 항목 보완 핵심. ★ v1.2.3 — required 필드 분리 (always vs api). lifecycle hook BR / 비-API BR 의 http_status/error_message 등은 null 의도 부재 허용 (★ DEC-2026-04-30-B-phase45-enrichment 정합).",
      "items": {
        "type": "object",
        "required": ["br_id", "trigger", "condition", "action", "expected_result", "verification_location", "current_state"],
        "properties": {
          "br_id": {
            "type": "string",
            "pattern": "^BR-[A-Z0-9_-]+-[A-Z0-9_-]+-[0-9]+$",
            "description": "BR ID (business-rules.json 정합)."
          },
          "trigger": {
            "type": "string",
            "description": "언제 발생. 예: HTTP endpoint, 이벤트, 스케줄, lifecycle hook."
          },
          "condition": {
            "type": "string",
            "description": "입력 조건. 빈 string 또는 '—' = 무조건 적용 (lifecycle hook BR 등)."
          },
          "action": {
            "type": "string",
            "description": "수행 액션."
          },
          "expected_result": {
            "type": "string",
            "description": "기대 결과."
          },
          "rejection_method": {
            "type": ["string", "null"],
            "description": "★ v1.2.3 — null 허용 (lifecycle hook BR 등 거부 의미 없음). API 영역 BR 의 거부 방식 — 자연어 누락 빈번."
          },
          "verification_location": {
            "type": "string",
            "description": "검증 위치 — 자연어 누락 빈번. 예: 'Domain Aggregate Root invariant', 'Service layer', 'Adapter', 'DB CHECK constraint', 'Entity lifecycle hook'."
          },
          "http_status": {
            "type": ["integer", "null"],
            "description": "★ v1.2.3 — null 허용 (lifecycle / 비-API BR). API 영역 BR 의 HTTP status code."
          },
          "error_code": {
            "type": ["string", "null"],
            "description": "에러 코드 (사내 표준). lifecycle BR 시 null."
          },
          "error_message": {
            "type": ["string", "null"],
            "description": "★ v1.2.3 — null 허용 (lifecycle BR / silent skip). 사용자 노출 메시지."
          },
          "current_state": {
            "type": "string",
            "enum": ["complete", "partial", "absent", "needs_review"],
            "description": "코드 구현 상태. absent 는 단방향 round-trip 후보."
          },
          "current_state_note": {
            "type": "string",
            "description": "★ v1.2.3 — current_state 부가 설명. enum 위반 회피 (★ PoC #03 F-156 패턴 — 한국어 prefix 분리). 'partial' / 'absent' 만 enum 으로, 부가 설명은 본 필드."
          },
          "rendered_md_path": {
            "type": "string"
          },
          "br_type": {
            "type": "string",
            "enum": ["api", "lifecycle", "domain_invariant", "performance", "security"],
            "description": "★ v1.2.3 — BR 분류. lifecycle = http_status/error_message null 허용. domain_invariant = entity 생성자 기반. v1.3 격상 시 enum 추가 가능."
          }
        }
      }
    },
    "invariants": {
      "type": "array",
      "description": "Aggregate Root 의 실행 가능 invariant (TypeScript 또는 Java).",
      "items": {
        "type": "object",
        "required": ["aggregate_root", "file_path"],
        "properties": {
          "aggregate_root": {"type": "string"},
          "file_path": {
            "type": "string",
            "description": "invariants/<AggregateRoot>.ts 또는 .java"
          },
          "language": {
            "type": "string",
            "enum": ["typescript", "java"]
          },
          "invariant_count": {
            "type": "integer",
            "description": "이 파일에 정의된 invariant 개수."
          },
          "related_brs": {
            "type": "array",
            "items": {"type": "string", "pattern": "^BR-[A-Z0-9_-]+-[A-Z0-9_-]+-[0-9]+$"}
          }
        }
      }
    },
    "property_tests": {
      "type": "array",
      "description": "fast-check (TS) 또는 jqwik (Java) property-based tests.",
      "items": {
        "type": "object",
        "required": ["aggregate_root", "file_path"],
        "properties": {
          "aggregate_root": {"type": "string"},
          "file_path": {"type": "string"},
          "language": {
            "type": "string",
            "enum": ["typescript", "java"]
          },
          "framework": {
            "type": "string",
            "enum": ["fast-check", "jqwik", "hypothesis", "scalacheck"]
          },
          "property_count": {"type": "integer"},
          "executed": {
            "type": "boolean",
            "description": "실제 실행 여부. false 시 신뢰도 -5%p 패널티."
          }
        }
      }
    },
    "generated_code": {
      "type": "array",
      "description": "단방향 round-trip 산출물 (코드 부재 BR — F-074 패턴).",
      "items": {
        "type": "object",
        "required": ["br_id", "file_path", "purpose"],
        "properties": {
          "br_id": {"type": "string"},
          "file_path": {"type": "string"},
          "purpose": {
            "type": "string",
            "enum": ["fix", "augmentation", "constraint"]
          },
          "language": {"type": "string"},
          "lines_added": {"type": "integer"}
        }
      }
    },
    "cross_validation": {
      "type": "object",
      "description": "Cross-validation 메타 (의무 — DEC-priority2 H).",
      "required": ["performed", "validators"],
      "properties": {
        "performed": {
          "type": "boolean",
          "description": "수행 여부. false 시 산출물 미완 — Phase 5-1 진입 차단 권고."
        },
        "validators": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "real_tool"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["senior_engineer_subagent", "static_analyzer_subagent", "external_tool", "user", "main_agent"]
              },
              "real_tool": {
                "type": "boolean",
                "description": "★★★ DEC-static-tool-실행-의무화 정합. true: 진짜 외부 도구 (Semgrep/PMD/SpotBugs/Daikon/CodeQL) → 5종 물증 의무. false: AI persona 시뮬 → simulation_reason 의무 + -5%p 패널티."
              },
              "simulation_reason": {
                "type": "string",
                "description": "real_tool=false 시 의무 — 시뮬 사용 사유 (예: 환경 부재, CI 미통합). lint-no-simulation.sh 가 grep 검증."
              },
              "tool_name": {"type": "string"},
              "tool_version": {
                "type": "string",
                "description": "물증 #1 — 진짜 도구 실행 시 의무 (e.g., semgrep --version 결과)."
              },
              "tool_stdout_path": {
                "type": "string",
                "description": "물증 #2 — raw stdout 로그 경로. real_tool=true 시 의무."
              },
              "tool_stderr_path": {
                "type": "string",
                "description": "물증 #3 — raw stderr 로그 경로. real_tool=true 시 의무."
              },
              "invocation_timestamp": {
                "type": "string",
                "format": "date-time",
                "description": "물증 #4 — 명령 실행 ISO timestamp. real_tool=true 시 의무."
              },
              "duration_ms": {
                "type": "integer",
                "description": "물증 #4b — 실행 소요시간 ms. real_tool=true 시 의무."
              },
              "result_hash": {
                "type": "string",
                "description": "물증 #5 — SARIF 결과 SHA256 hash. real_tool=true 시 의무. 결과 위조 차단."
              },
              "reproduction_command": {
                "type": "string",
                "description": "물증 #6 — 사용자가 재현 가능한 전체 명령. real_tool=true 시 의무."
              },
              "findings_discovered": {"type": "integer"}
            },
            "allOf": [
              {
                "if": {"properties": {"real_tool": {"const": true}}},
                "then": {
                  "required": ["tool_name", "tool_version", "tool_stdout_path", "tool_stderr_path", "invocation_timestamp", "duration_ms", "result_hash", "reproduction_command"]
                }
              },
              {
                "if": {"properties": {"real_tool": {"const": false}}},
                "then": {
                  "required": ["simulation_reason"]
                }
              }
            ]
          }
        },
        "simulation_only": {
          "type": "boolean",
          "description": "★★★ Sprint 4 묶음 O — validators 전체가 시뮬인 경우 자동 fail. lint-no-simulation.sh enforcement."
        },
        "double_hits": {
          "type": "integer",
          "description": "Senior + Static 양쪽 발견 finding 수 (★★ 격상 후보)."
        },
        "drift_detected": {
          "type": "integer",
          "description": "이중 렌더링 drift (.json ↔ .mermaid 불일치) 수."
        }
      }
    }
  }
}
