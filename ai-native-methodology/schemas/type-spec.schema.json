{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-native-methodology/schemas/type-spec.schema.json",
  "title": "Type Spec (★ v1.4 Stage 7-pre 신설 — TypeScript .d.ts 추출)",
  "description": "Deliverable #15. TypeScript 타입 정보 추출 — framework-neutral L1 Domain (ADR-FE-006 정합). ADR-FE-005 매개체 #6 (.d.ts) 채택의 정식 산출 절차. 외부 LLM 검증 빈틈 #2 해소.",
  "x-spec-source": {
    "typescript": "https://www.typescriptlang.org/docs/handbook/declaration-files/introduction.html",
    "ts_morph": "https://ts-morph.com/"
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "types", "summary"],
  "properties": {
    "meta": { "$ref": "./meta-confidence.schema.json" },
    "scope": {
      "type": "object",
      "description": "추출 범위 (★ scope 한정 의무 — 모든 TS 타입 추출 시 비대 위험).",
      "properties": {
        "exported_only": {
          "type": "boolean",
          "default": true,
          "description": "★ export 된 타입만 추출 권장 (private internal type 제외)."
        },
        "domain_linked_only": {
          "type": "boolean",
          "default": false,
          "description": "domain.json E-XXX 와 연결된 타입만 추출 (★ 더 좁은 scope)."
        },
        "include_dirs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "exclude_patterns": {
          "type": "array",
          "items": { "type": "string" },
          "description": "예: ['**/*.test.ts', '**/node_modules/**']"
        }
      }
    },
    "types": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "kind", "source_file"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^T-[A-Z0-9_-]+-\\d+$",
            "description": "Type ID. 예: T-USER-001."
          },
          "name": {
            "type": "string",
            "description": "타입 이름 (예: 'User', 'OrderItem', 'ApiResponse<T>')."
          },
          "kind": {
            "type": "string",
            "enum": [
              "interface",
              "type_alias",
              "enum",
              "class",
              "union",
              "intersection",
              "tuple",
              "namespace",
              "function_signature"
            ]
          },
          "declaration": {
            "type": "string",
            "description": "★ .d.ts 형식 declaration 문자열 (재추출 의무 — JSDoc 보존)."
          },
          "is_generic": { "type": "boolean" },
          "generic_params": {
            "type": "array",
            "items": { "type": "string" }
          },
          "properties": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "optional": { "type": "boolean" },
                "readonly": { "type": "boolean" },
                "jsdoc": { "type": "string" }
              }
            }
          },
          "extends": {
            "type": "array",
            "items": { "type": "string" }
          },
          "implements": {
            "type": "array",
            "items": { "type": "string" }
          },
          "references": {
            "type": "array",
            "items": { "type": "string" },
            "description": "본 타입이 참조하는 다른 타입 ID 또는 이름."
          },
          "domain_entity_id": {
            "type": "string",
            "pattern": "^E-[A-Z0-9_-]+(-\\d+)?$",
            "description": "★ domain.json E-XXX cross-link (있을 시)."
          },
          "framework_coupling_score": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "★ ADR-FE-006 정합 — framework 종속도 (0=완전 중립 / 1=React/Vue/Angular 종속). React.FC / @types/react 직접 참조 시 ↑."
          },
          "framework_coupling_reasons": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "react_fc_import",
                "react_node_import",
                "react_props_pattern",
                "vue_setup_helper",
                "vue_defineProps_macro",
                "angular_decorator",
                "angular_observable",
                "rxjs_import"
              ]
            }
          },
          "source_file": { "type": "string" },
          "source_line": { "type": "integer", "minimum": 1 },
          "exported": { "type": "boolean" }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total_types"],
      "properties": {
        "total_types": { "type": "integer", "minimum": 0 },
        "per_kind": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "domain_linked_count": {
          "type": "integer",
          "minimum": 0,
          "description": "domain.json E-XXX 와 연결된 타입 개수."
        },
        "framework_neutrality_score": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "★ 핵심 metric — 전체 타입 중 framework_coupling_score=0 인 타입 비율. 1.0 = 모든 타입 framework-neutral."
        },
        "framework_coupled_count": {
          "type": "integer",
          "minimum": 0,
          "description": "★ framework_coupling_score > 0 인 타입 개수 → 신규 스택 정해진 후 재추출 권장."
        },
        "captured_by": {
          "type": "string",
          "enum": ["ts_morph_real", "tsc_real", "typedoc_real", "manual_extraction", "simulation"],
          "description": "★ no-simulation 정책."
        },
        "captured_by_version": { "type": "string" },
        "stdout_path": { "type": "string" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "reproduction_command": { "type": "string" },
        "result_hash": { "type": "string" },
        "simulation_reason": { "type": "string" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "captured_by": {
                "enum": ["ts_morph_real", "tsc_real", "typedoc_real"]
              }
            }
          },
          "then": {
            "required": ["captured_by_version", "duration_ms", "reproduction_command"]
          }
        },
        {
          "if": {
            "properties": { "captured_by": {"const": "simulation"} }
          },
          "then": {
            "required": ["simulation_reason"]
          }
        }
      ]
    },
    "cross_links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from_type", "to_artifact", "to_id", "link_type"],
        "properties": {
          "from_type": { "type": "string" },
          "to_artifact": {
            "type": "string",
            "enum": ["domain", "rules", "ui-spec", "state-map", "form-validation-spec", "api"]
          },
          "to_id": { "type": "string" },
          "link_type": {
            "type": "string",
            "enum": [
              "represents_entity",
              "constrains_field",
              "constrains_state",
              "matches_zod_schema",
              "matches_openapi_schema",
              "props_of_component"
            ]
          }
        }
      }
    }
  }
}
