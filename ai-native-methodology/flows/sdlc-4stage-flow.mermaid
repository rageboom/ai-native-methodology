%% ★ ★ ★ v2.0 SDLC 4단계 chain harness 통합 SSOT (사람 눈)
%% AI 눈 짝: sdlc-4stage-flow.json (drift-validator 호환)
%% master plan §B 정합 / DEC-2026-05-06-v2.0-i-strict-채택

flowchart TB
    subgraph S0["★ Stage 0 — Analysis (1차 input / sub_flow: analysis.phase-flow.json)"]
        direction LR
        S0_OUT["7대 BE + 8 FE + Phase 4.5 + finding + AP + migration"]
    end

    subgraph S1["★ Chain 1 — Planning (sub_flow: planning.phase-flow.json)"]
        direction LR
        S1_OUT["planning-spec.{json,md} (deliverable 17)"]
    end

    subgraph S2["★ Chain 2 — Spec (sub_flow: spec.phase-flow.json)"]
        direction LR
        S2_OUT["behavior-spec.json (deliverable 18)<br/>acceptance-criteria.json (deliverable 19)"]
    end

    subgraph S3["★ Chain 3 — Test / RED 의무 (sub_flow: test.phase-flow.json)"]
        direction LR
        S3_OUT["test-spec.json (deliverable 20) + 실 test 코드<br/>★ 5종 물증 7 필드 / fail_count > 0"]
    end

    subgraph S4["★ ★ ★ Chain 4 — Implement / GREEN 의무 / i-strict (sub_flow: implement.phase-flow.json)"]
        direction LR
        S4_OUT["impl-spec.json (deliverable 21) + 실 impl 코드<br/>★ test_pass_evidence.fail_count: 0<br/>traceability-matrix.{json,md,mermaid}"]
    end

    subgraph G["★ ★ ★ 4 Gate (사용자 결단 / invoke-go-stop-gate skill)"]
        G1["Gate #1<br/>planning-extraction-validator<br/>schema-validator"]
        G2["Gate #2<br/>chain-coverage-validator<br/>drift / dmn / formal-link / schema"]
        G3["Gate #3<br/>test-impl-pass (RED expected: all_fail)<br/>spec-test-link / schema / chain-strict lint"]
        G4["Gate #4 (final)<br/>test-impl-pass (GREEN expected: all_pass)<br/>static-runner 6종 / matrix 100% green / chain-strict"]
    end

    subgraph CC["Cross-cutting"]
        CC1["★ ★ ★ no-simulation 정책<br/>(chain-strict lint + --allow-execute + 진짜 도구 7종)"]
        CC2["traceability bidirectional<br/>(DO-178C / IEC 62304)"]
        CC3["ratchet 0.85 → 0.90 → 0.95<br/>severity_floor: critical=1.0 / high=0.95"]
        CC4["chain-revisit-detector<br/>(★ sub-plan-5 carry)"]
    end

    subgraph REL["Release 자격 (§8.1 strict 7/7 / sub-plan-6)"]
        R["1. ≥ 2 PoC corroboration<br/>2. 진짜 도구 5종 물증<br/>3. 0 violation<br/>4. coverage ≥ 0.85<br/>5. ADR-CHAIN-001~004 + ADR-008/009/010 v2<br/>6. matrix 100% green<br/>7. e2e cycle 1 BR + 1 UC + 1 TC + 1 IMPL"]
    end

    %% main flow
    S0 --> S1
    S1 --> G1
    G1 -->|"go"| S2
    S2 --> G2
    G2 -->|"go"| S3
    S3 --> G3
    G3 -->|"go (RED 확정)"| S4
    S4 --> G4
    G4 -->|"go"| REL

    %% revisit edges (★ chain harness gate 안 round-trip 정식 허용)
    G1 -.->|"revisit:analysis"| S0
    G2 -.->|"revisit:planning"| S1
    G3 -.->|"revisit:spec"| S2
    G4 -.->|"revisit:test"| S3
    G4 -.->|"revisit:spec"| S2
    G4 -.->|"revisit:planning"| S1

    %% stop edges
    G1 -.->|"stop"| STOP["sprint 중단 / carry"]
    G2 -.->|"stop"| STOP
    G3 -.->|"stop"| STOP
    G4 -.->|"stop"| STOP

    %% cross-cutting
    S1 -.-> CC
    S2 -.-> CC
    S3 -.-> CC
    S4 -.-> CC

    %% Style
    classDef stage0 fill:#e1f5fe,stroke:#01579b,stroke-width:2px
    classDef chain1 fill:#e3f2fd,stroke:#1565c0,stroke-width:3px
    classDef chain2 fill:#fff8e1,stroke:#ef6c00,stroke-width:3px
    classDef chain3 fill:#fce4ec,stroke:#ad1457,stroke-width:3px
    classDef chain4 fill:#e8f5e9,stroke:#2e7d32,stroke-width:3px
    classDef gate fill:#fff3cd,stroke:#856404,stroke-width:3px
    classDef cross fill:#e2e3e5,stroke:#383d41
    classDef rel fill:#cce5ff,stroke:#004085,stroke-width:2px
    classDef stop fill:#f8d7da,stroke:#721c24

    class S0 stage0
    class S1 chain1
    class S2 chain2
    class S3 chain3
    class S4 chain4
    class G gate
    class CC cross
    class REL rel
    class STOP stop
