{
  "$comment": "★ ★ v2.0 chain 4 (test) phase flow (★ v9.0 plan 신설로 재번호 / 구 chain 3 / ★ v10.0.0 MAJOR gate #3→#4 재번호 chain N=gate #N) — AI 눈 짝 (test.phase-flow.mermaid 의 SSOT). DEC-2026-05-06-v2.0-i-strict-채택 + ADR-CHAIN-001 §3 + ADR-CHAIN-004 정합. acceptance-criteria 기반 실 test 코드 자동 generate (RED 의무 / impl 부재 가정 모든 test fail). ★ ★ ★ v3.1.0 — phase ID 의미 ID 자산화 (D-3 paradigm / depends_on 그래프 SSOT / order 필드 폐기 / 위상정렬 자동).",
  "id": "test-phase-flow",
  "version": "3.1.0",
  "stage": "test",
  "chain": 4,
  "rendered_mermaid_path": "./test.phase-flow.mermaid",
  "phases": [
    {
      "id": "framework-detect",
      "name": "framework 추론 (inventory + .aimd/config/test-cmd)",
      "depends_on": [],
      "inputs": ["acceptance-criteria.json", "behavior-spec.json", "inventory.json", ".aimd/config/test-cmd.json"],
      "outputs": ["framework_resolved", "test_cmd_resolved"],
      "skills": ["test-generate-test-spec"],
      "adr_ref": "ADR-CHAIN-004"
    },
    {
      "id": "tc-decompose",
      "name": "TC-* 분해 (1 AC = 1 TC)",
      "depends_on": ["framework-detect"],
      "inputs": ["acceptance-criteria.criteria[]"],
      "outputs": ["test-spec.json (test_cases[])"],
      "skills": ["test-generate-test-spec"]
    },
    {
      "id": "test-code-generate",
      "name": "실 test 코드 generate (RED 의무 / ★ v3.4.0 G4: e2e 는 test-playwright 위임)",
      "depends_on": ["tc-decompose"],
      "inputs": ["test-spec.test_cases", "behavior-spec.property_tests"],
      "outputs": ["test source files (jest/vitest/junit5/pytest 등 / ★ v3.4.0 e2e = Playwright POM)"],
      "skills": ["test-generate-test-spec", "test-playwright"],
      "expected_outcome": "all_fail"
    },
    {
      "id": "ac-tc-backlink",
      "name": "AC.test_case_refs backward 채움",
      "depends_on": ["test-code-generate"],
      "inputs": ["test-spec.json", "acceptance-criteria.json"],
      "outputs": ["acceptance-criteria.criteria[].test_case_refs[]"],
      "skills": ["test-generate-test-spec"]
    },
    {
      "id": "red-evidence",
      "name": "RED 검증 + evidence (5종 물증 10 필드)",
      "depends_on": ["test-code-generate", "ac-tc-backlink"],
      "inputs": ["test source files", ".aimd/config/test-cmd.json"],
      "outputs": ["test-spec.test_cases[].test_run_evidence (RED / S1·greenfield fail_count > 0 / S2 per_tc_outcome)"],
      "skills": ["test-run-test-evidence"],
      "automated_validation": ["test-impl-pass-validator (--allow-execute / expected: all_fail)", "schema-validator", "spec-test-link-validator", "lint-no-simulation (chain-strict)"]
    },
    {
      "id": "coverage-measure",
      "name": "coverage 측정 (3 metric 분리)",
      "depends_on": ["red-evidence"],
      "inputs": ["test-spec.json", "acceptance-criteria.json"],
      "outputs": ["test-spec.coverage"],
      "skills": ["test-verify-coverage"]
    },
    {
      "id": "gate-4",
      "name": "go/stop gate #4",
      "depends_on": ["red-evidence", "coverage-measure"],
      "inputs": ["test-spec.json", "validator_findings"],
      "outputs": ["chain-intervention-log.jsonl", "go|stop|revisit"],
      "skills": ["_base-invoke-go-stop-gate"],
      "gate": "#4"
    }
  ],
  "cross_cutting": {
    "validators": ["test-impl-pass-validator", "spec-test-link-validator", "schema-validator", "lint-no-simulation (chain-strict)"],
    "ratchet_threshold": 0.85,
    "expected_outcome_chain4": "all_fail (RED 의무)",
    "no_simulation": true,
    "allow_execute_required": true
  },
  "previous_chain": {
    "id": "plan",
    "flow_file": "plan.phase-flow.json"
  },
  "next_chain": {
    "id": "implement",
    "flow_file": "implement.phase-flow.json",
    "gate_decision": "go"
  }
}
