%% AI-Native 방법론 — Phase 흐름 + 산출물 의존 그래프
%% v3.0.0 — ★ phase ID 의미 ID rename (D-3 paradigm / depends_on 그래프 SSOT / 위상정렬 자동 도출).
%% 사람 눈 (mermaid). AI 눈 짝: phase-flow.json (drift-validator 호환).
%% subgraph id 표기 = `P_<semantic_id>` (P 접두사 + underscore — mermaid 문법 호환 + drift-validator P prefix 정규식 호환).
%% drift-validator 의 derivePhaseIdFromSubId 가 `P_db_schema` → `db-schema` 자동 변환.
%% ADR-008 (이중 렌더링) + ADR-CHAIN-006 (characterization) + ADR-CHAIN-007 (sql-inventory) 정합.

flowchart TB
    %% ═════════════ input ═════════════
    subgraph P_input["Phase input — 입력 정리"]
        direction LR
        input_IN["소스 (필수)<br/>+ ERD / ORM / 기획 (선택)"]
        input_OUT["_manifest.yml (입력)"]
        input_IN --> input_OUT
    end

    %% ═════════════ discovery ═════════════
    subgraph P_discovery["Phase discovery — 탐색 (인벤토리 추출)"]
        direction LR
        discovery_OUT["inventory.json<br/>tree.md + stack-detection.md<br/>stats.json"]
    end

    %% ═════════════ db-schema ═════════════
    subgraph P_db_schema["Phase db-schema — DB 스키마"]
        direction LR
        db_schema_OUT["schema.json + schema.sql<br/>erd.mermaid<br/>정합성-검증-보고서.md"]
    end

    %% ═════════════ architecture ═════════════
    subgraph P_architecture["Phase architecture — 아키텍처"]
        direction LR
        architecture_OUT["architecture.json<br/>architecture.mermaid + .md<br/>dependency-graph.mermaid<br/>circular-dependencies.md"]
    end

    %% ═════════════ business-logic (4영역 병렬) ═════════════
    subgraph P_business_logic["Phase business-logic — 비즈니스 로직 (4영역 병렬)"]
        direction TB
        BL_A["5.A rules<br/>(BR 추출)"]
        BL_B["5.B domain<br/>(Aggregate Root)"]
        BL_C["5.C antipatterns-partial<br/>(부분 추출)"]
        BL_D["5.D ui-domain<br/>(UI 도메인)"]
        BL_OUT["domain.json + domain.mermaid + .md<br/>business-rules.json + rules.md<br/>antipatterns-partial.json"]
        BL_A --> BL_OUT
        BL_B --> BL_OUT
        BL_C --> BL_OUT
        BL_D --> BL_OUT
    end

    %% ═════════════ formal-spec (★ v1.2.0 신설 / v1.2.1 자동 검증) ═════════════
    subgraph P_formal_spec["Phase formal-spec — 형식 명세 (★ v1.2.0)"]
        direction LR
        formal_spec_OUT["state-machines/*.json + .mermaid<br/>sequence-diagrams/*.json + .mermaid<br/>decision-tables/*.json + .md<br/>invariants/*.ts<br/>property-tests/*.spec.ts"]
        formal_spec_VAL["★ v1.2.1 자동 검증<br/>drift-validator + decision-table-validator"]
        formal_spec_OUT --> formal_spec_VAL
    end

    %% ═════════════ characterization (★ v2.1.0 신설 — 의도 vs 버그 분리) ═════════════
    subgraph P_characterization["Phase characterization — 특성화 (★ v2.1.0)"]
        direction LR
        characterization_OUT["characterization-spec.json<br/>intent-vs-bug.md<br/>coverage.json<br/>snapshots/UC-*.json"]
        characterization_VAL["★ v2.1.0 자동 검증<br/>characterization-coverage-validator"]
        characterization_OUT --> characterization_VAL
    end

    %% ═════════════ sql-inventory (★ v2.2.0-rc1 신설 / RDB 한정) ═════════════
    subgraph P_sql_inventory["Phase sql-inventory — SQL 인벤토리 (★ v2.2.0-rc1 / RDB 한정)"]
        direction LR
        sql_inventory_OUT["sql-inventory.json (11 컬럼)<br/>sql-inventory.md<br/>raw-grep.txt"]
        sql_inventory_VAL["★ v2.2.0-rc1 자동 검증<br/>sql-inventory-validator"]
        sql_inventory_OUT --> sql_inventory_VAL
    end

    %% ═════════════ api / ui (병렬) ═════════════
    subgraph P_api["Phase api — API 계약"]
        api_OUT["openapi.yaml + api.md<br/>api-extension.json"]
    end
    subgraph P_ui["Phase ui — UI"]
        ui_OUT["ui-spec.json + ui-spec.md + .mermaid"]
    end

    %% ═════════════ quality ═════════════
    subgraph P_quality["Phase quality — 품질 (안티패턴 통합)"]
        direction LR
        quality_OUT["antipatterns.json<br/>avoid-list.md<br/>migration-cautions.md (★ v1.2.0)"]
    end

    %% ═════════════ Cross-cutting (모든 phase) ═════════════
    subgraph CC["Cross-cutting"]
        direction LR
        CC_FIND["findings/poc-findings.md<br/>(F-NNN — finding-system schema)"]
        CC_DEC["decisions/<br/>(DEC-YYYY-MM-DD-* / INDEX.md / STATUS.md)"]
        CC_META["_manifest.yml per phase<br/>(meta-confidence + cross_validation)"]
    end

    %% ═════════════ 의존 그래프 ═════════════
    P_input --> P_discovery
    P_discovery --> P_db_schema
    P_discovery --> P_architecture
    P_db_schema --> P_architecture
    P_discovery --> P_business_logic
    P_db_schema --> P_business_logic
    P_architecture --> P_business_logic
    P_business_logic --> P_formal_spec
    P_business_logic --> P_characterization
    P_formal_spec --> P_characterization
    P_discovery --> P_sql_inventory
    P_business_logic --> P_sql_inventory
    P_characterization --> P_sql_inventory
    P_business_logic --> P_api
    P_formal_spec --> P_api
    P_characterization --> P_api
    P_sql_inventory --> P_api
    P_business_logic --> P_ui
    P_architecture --> P_ui
    P_characterization --> P_ui
    P_api --> P_quality
    P_ui --> P_quality
    P_formal_spec --> P_quality
    P_business_logic --> P_quality

    %% 산출물 cross-cutting
    P_discovery -.-> CC_FIND
    P_db_schema -.-> CC_FIND
    P_architecture -.-> CC_FIND
    P_business_logic -.-> CC_FIND
    P_formal_spec -.-> CC_FIND
    P_characterization -.-> CC_FIND
    P_api -.-> CC_FIND
    P_ui -.-> CC_FIND
    P_quality -.-> CC_FIND

    %% Style
    classDef new_formal fill:#fff3cd,stroke:#856404,stroke-width:3px
    classDef new_char fill:#cce5ff,stroke:#004085,stroke-width:3px
    classDef quality_style fill:#d4edda,stroke:#155724,stroke-width:2px
    classDef cross fill:#e2e3e5,stroke:#383d41
    class P_formal_spec new_formal
    class P_characterization new_char
    class P_quality quality_style
    class CC cross
