{
  "$comment": "v11.0.0 chain 1 (discovery) phase flow — json 단독 SSOT (v12 ADR-011 / .mermaid 짝 폐기). DEC-2026-05-06-v2.0-i-strict-채택 + ADR-CHAIN-001 + v9.0 DEC-2026-05-21 (planning→discovery 개칭 + 입력 어댑터 4종 확장) + v11.0.0 DEC-2026-05-26-discovery-spec-rename (산출물명 본격 rename) 정합. analysis stage 산출물 + 외부 입력(swagger/figma/nl-md) → discovery-spec.{json,md} 산출. v3.1.0 — phase ID 의미 ID 자산화 (D-3 paradigm / depends_on 그래프 SSOT / order 필드 폐기 / 위상정렬 자동).",
  "id": "discovery-phase-flow",
  "version": "3.1.0",
  "stage": "discovery",
  "chain": 1,
  "phases": [
    {
      "id": "input-validate",
      "name": "input 검증 (analysis-output / swagger / figma / nl-md 어댑터)",
      "depends_on": [],
      "inputs": ["analysis_outputs", "finding_system", "antipatterns", "migration_cautions", "swagger", "figma", "nl_md"],
      "outputs": ["analysis_completeness_check"],
      "skills": ["discovery-from-analysis-output", "discovery-from-swagger", "discovery-from-figma", "discovery-from-nl-md"]
    },
    {
      "id": "use-cases-decompose",
      "name": "use_cases 분해",
      "depends_on": ["input-validate"],
      "inputs": ["domain.json", "business-rules.json", "api-extension.json", "state-machines/*.json"],
      "outputs": ["use_cases[]"],
      "skills": ["discovery-decompose-use-cases"]
    },
    {
      "id": "br-intent-extract",
      "name": "business_rules_intent 추출",
      "depends_on": ["input-validate"],
      "inputs": ["business-rules.json", "antipatterns.json", "finding-system.findings.json"],
      "outputs": ["business_rules_intent[]"],
      "skills": ["discovery-identify-business-intent"]
    },
    {
      "id": "discovery-spec-compose",
      "name": "discovery-spec 합성 + 검증",
      "depends_on": ["use-cases-decompose", "br-intent-extract"],
      "inputs": ["use_cases", "business_rules_intent", "business_intent"],
      "outputs": ["discovery-spec.json"],
      "skills": ["discovery-from-analysis-output"],
      "automated_validation": ["discovery-extraction-validator", "schema-validator"]
    },
    {
      "id": "gate-1",
      "name": "go/stop gate #1",
      "depends_on": ["discovery-spec-compose"],
      "inputs": ["discovery-spec.json", "validator_findings"],
      "outputs": ["chain-intervention-log.jsonl", "go|stop|revisit"],
      "skills": ["_base-invoke-go-stop-gate"],
      "gate": "#1"
    }
  ],
  "cross_cutting": {
    "validators": ["discovery-extraction-validator", "schema-validator", "formal-spec-link-validator (--chain-mode)", "br-cross-consistency-validator"],
    "no_simulation": true,
    "source_grounded_required": true
  },
  "next_chain": {
    "id": "spec",
    "flow_file": "spec.phase-flow.json",
    "gate_decision": "go"
  }
}
