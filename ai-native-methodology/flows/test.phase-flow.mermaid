%% ★ ★ v2.0 chain 4 (test) phase flow — 사람 눈 (mermaid)
%% AI 눈 짝: test.phase-flow.json (drift-validator 호환)
%% ★ ★ ★ v3.1.0 — phase ID 의미 ID rename (D-3 paradigm / depends_on 그래프 SSOT / 위상정렬 자동).
%% subgraph id = `P_<semantic_id>` (P 접두사 + underscore — mermaid 문법 호환 + drift-validator 정규식 호환).
%% ADR-008 v2 §10 + ADR-CHAIN-001 §3 + ADR-CHAIN-004 정합

flowchart TB
    subgraph C3["★ Chain 4 — test (RED 의무)"]
        direction TB

        P_framework_detect["Phase framework-detect — framework 추론<br/>inventory + .aimd/config/test-cmd<br/>(★ ADR-CHAIN-004 Aider 패턴)"]
        P_tc_decompose["Phase tc-decompose — TC-* 분해 (1 AC = 1 TC)"]
        P_test_code_generate["★ ★ ★ Phase test-code-generate — 실 test 코드 generate (RED)<br/>jest / vitest / junit5 / pytest"]
        P_ac_tc_backlink["Phase ac-tc-backlink — AC.test_case_refs backward 채움"]
        P_red_evidence["★ ★ ★ Phase red-evidence — RED 검증 + 5종 물증 7 필드<br/>test-impl-pass-validator (--allow-execute / expected: all_fail)<br/>+ lint-no-simulation chain-strict"]
        P_coverage_measure["Phase coverage-measure — coverage 측정 (3 metric 분리)<br/>test-verify-coverage"]
        P_gate_4["★ ★ ★ Phase gate-4 — go/stop gate #4 (사용자 결단)<br/>_base-invoke-go-stop-gate"]

        P_framework_detect --> P_tc_decompose
        P_tc_decompose --> P_test_code_generate
        P_test_code_generate --> P_ac_tc_backlink
        P_test_code_generate --> P_red_evidence
        P_ac_tc_backlink --> P_red_evidence
        P_red_evidence --> P_coverage_measure
        P_red_evidence --> P_gate_4
        P_coverage_measure --> P_gate_4
    end

    subgraph IN["chain 2 (spec)"]
        IN_OUT["acceptance-criteria.json + behavior-spec.json<br/>+ inventory.json + .aimd/config/test-cmd.json"]
    end

    subgraph OUT["chain 4 (test) 산출물"]
        direction LR
        OUT_TS["test-spec.json (deliverable 20)"]
        OUT_CODE["실 test 코드 (RED — S1/greenfield fail / S2 per_tc_outcome)"]
        OUT_EV["test_cases[].test_run_evidence (5종 물증 10 필드)"]
    end

    subgraph NEXT["chain 5 (impl) 진입"]
        N1["implement-generate-impl-spec skill"]
    end

    IN --> P_framework_detect
    P_test_code_generate --> OUT_CODE
    P_red_evidence --> OUT_TS
    P_red_evidence --> OUT_EV
    P_gate_4 -->|"go (RED 확정)"| NEXT
    P_gate_4 -.->|"stop"| STOP["sprint 중단"]
    P_gate_4 -.->|"revisit:spec"| IN

    classDef chain3 fill:#fce4ec,stroke:#ad1457,stroke-width:3px
    classDef gate fill:#fff3cd,stroke:#856404,stroke-width:3px
    classDef out fill:#d4edda,stroke:#155724,stroke-width:2px
    classDef stop fill:#f8d7da,stroke:#721c24
    classDef red fill:#f8d7da,stroke:#721c24,stroke-width:2px
    class C3 chain3
    class P_gate_4 gate
    class P_test_code_generate red
    class OUT out
    class STOP stop
