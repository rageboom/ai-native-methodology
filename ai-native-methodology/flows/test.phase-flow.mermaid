%% ★ ★ v2.0 chain 3 (test) phase flow — 사람 눈 (mermaid)
%% AI 눈 짝: test.phase-flow.json (drift-validator 호환)
%% ADR-008 v2 §10 + ADR-CHAIN-001 §3 + ADR-CHAIN-004 정합

flowchart TB
    subgraph C3["★ Chain 3 — test (RED 의무)"]
        direction TB

        P30["P3.0 — framework 추론<br/>inventory + .aimd/config/test-cmd<br/>(★ ADR-CHAIN-004 Aider 패턴)"]
        P31["P3.1 — TC-* 분해 (1 AC = 1 TC)"]
        P32["★ ★ ★ P3.2 — 실 test 코드 generate (RED)<br/>jest / vitest / junit5 / pytest"]
        P33["P3.3 — AC.test_case_refs backward 채움"]
        P34["★ ★ ★ P3.4 — RED 검증 + 5종 물증 7 필드<br/>test-impl-pass-validator (--allow-execute / expected: all_fail)<br/>+ lint-no-simulation chain-strict"]
        P35["P3.5 — coverage 측정 (3 metric 분리)<br/>test-verify-coverage"]
        P36["★ ★ ★ P3.6 — gate #3 (사용자 결단)<br/>_base-invoke-go-stop-gate"]

        P30 --> P31
        P31 --> P32
        P32 --> P33
        P32 --> P34
        P33 --> P34
        P34 --> P35
        P35 --> P36
    end

    subgraph IN["chain 2 (spec)"]
        IN_OUT["acceptance-criteria.json + behavior-spec.json<br/>+ inventory.json + .aimd/config/test-cmd.json"]
    end

    subgraph OUT["chain 3 산출물"]
        direction LR
        OUT_TS["test-spec.json (deliverable 20)"]
        OUT_CODE["실 test 코드 (RED — 모든 test fail)"]
        OUT_EV["test_invocation_evidence (5종 물증 7 필드)"]
    end

    subgraph NEXT["chain 4 (impl) 진입"]
        N1["implement-generate-impl-spec skill"]
    end

    IN --> P30
    P32 --> OUT_CODE
    P34 --> OUT_TS
    P34 --> OUT_EV
    P36 -->|"go (RED 확정)"| NEXT
    P36 -.->|"stop"| STOP["sprint 중단"]
    P36 -.->|"revisit:spec"| IN

    classDef chain3 fill:#fce4ec,stroke:#ad1457,stroke-width:3px
    classDef gate fill:#fff3cd,stroke:#856404,stroke-width:3px
    classDef out fill:#d4edda,stroke:#155724,stroke-width:2px
    classDef stop fill:#f8d7da,stroke:#721c24
    classDef red fill:#f8d7da,stroke:#721c24,stroke-width:2px
    class C3 chain3
    class P36 gate
    class P32 red
    class OUT out
    class STOP stop
