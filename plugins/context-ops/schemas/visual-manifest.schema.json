{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-native-methodology/schemas/visual-manifest.schema.json",
  "title": "Visual Manifest (시각 산출 매니페스트)",
  "description": "Deliverable #9 (v1.4 신설). FE 영역 시각 산출 (Playwright snapshot + axe-core a11y inline). binary 진실 (snapshot PNG) 모델 — ADR-FE-002 §2.3 visual 예외 정합. ADR-009 §2.4.2 binary trust path 정합. drift-validator 적용 ❌ / Playwright snapshot diff ✅. no-simulation 정책 강제.",
  "x-spec-source": {
    "playwright": "https://playwright.dev/docs/test-snapshots",
    "axe_core": "https://github.com/dequelabs/axe-core/blob/develop/doc/API.md",
    "wcag": "https://www.w3.org/TR/WCAG22/",
    "wcag_versions": ["2.1", "2.2"]
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "snapshots", "manifest_summary"],
  "properties": {
    "meta": {
      "$ref": "./meta-confidence.schema.json"
    },
    "framework": {
      "type": "string",
      "enum": [
        "react", "vue", "angular", "svelte", "solid", "qwik", "astro",
        "next", "nuxt", "remix",
        "vanilla_js", "jquery_legacy", "jsp_template",
        "unknown"
      ],
      "description": "감지된 FE 프레임워크 (ui-spec.schema.json framework enum 정합)."
    },
    "viewport_matrix": {
      "type": "array",
      "description": "캡처 viewport 매트릭스. 매트릭스 정의 의무 (snapshot 일관성 진실 모델).",
      "items": {
        "type": "object",
        "required": ["label", "width", "height"],
        "properties": {
          "label": {
            "type": "string",
            "description": "viewport 라벨 (예: 'desktop', 'tablet', 'mobile-portrait', 'mobile-landscape')."
          },
          "width": {"type": "integer", "minimum": 320, "maximum": 3840},
          "height": {"type": "integer", "minimum": 240, "maximum": 2160},
          "dpr": {
            "type": "number",
            "minimum": 1.0,
            "maximum": 4.0,
            "default": 1.0,
            "description": "Device Pixel Ratio. retina=2, 일반=1."
          },
          "user_agent": {
            "type": "string",
            "description": "User-Agent override (선택)."
          }
        }
      },
      "minItems": 1
    },
    "locale_matrix": {
      "type": "array",
      "description": "다국어 viewport 매트릭스 (선택). i18n 영향 검증.",
      "items": {
        "type": "object",
        "required": ["locale"],
        "properties": {
          "locale": {
            "type": "string",
            "description": "BCP 47 locale tag (예: 'ko-KR', 'en-US', 'ja-JP')."
          },
          "label": {"type": "string"}
        }
      }
    },
    "snapshots": {
      "type": "array",
      "description": "snapshot 항목 목록. 각 항목 = 1 page × 1 viewport × 1 locale (옵션) 의 PNG.",
      "items": {
        "type": "object",
        "required": ["id", "page_id", "viewport_label", "snapshot_path", "snapshot_hash", "captured_by"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^VIS-[A-Z0-9_-]+-\\d+$",
            "description": "Visual snapshot ID. 예: VIS-LOGIN-001."
          },
          "page_id": {
            "type": "string",
            "pattern": "^PAGE-[A-Z0-9_-]+-\\d+$",
            "description": "ui-spec.json pages[] cross-link."
          },
          "component_id": {
            "type": "string",
            "pattern": "^CMP-[A-Z0-9_-]+$",
            "description": "특정 컴포넌트 snapshot 시 ID (선택). ui-spec.json components[] cross-link."
          },
          "story_id": {
            "type": "string",
            "description": "Storybook CSF v3 story ID (선택). 'group/component--story-name' 형식."
          },
          "viewport_label": {
            "type": "string",
            "description": "viewport_matrix[].label 참조."
          },
          "locale": {
            "type": "string",
            "description": "BCP 47 locale tag (선택). locale_matrix 사용 시."
          },
          "snapshot_path": {
            "type": "string",
            "description": "binary 진실 — snapshot PNG 파일 상대 경로."
          },
          "snapshot_hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$",
            "description": "SHA-256 hash (64 hex chars). binary 진실 fingerprint."
          },
          "baseline_hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$",
            "description": "비교 baseline hash. 사람 승인 baseline 갱신 시에만 변경."
          },
          "diff_status": {
            "type": "string",
            "enum": ["match", "drift", "baseline_new", "baseline_pending_approval"],
            "description": "diff 상태. match=baseline 일치, drift=차이 발견 (사람 검토 필요), baseline_new=신규, baseline_pending_approval=사람 승인 대기."
          },
          "diff_pixel_count": {
            "type": "integer",
            "minimum": 0,
            "description": "픽셀 차이 개수 (drift 시)."
          },
          "diff_threshold": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "허용 픽셀 차이 비율 (0.0~1.0). 기본 0.0 (엄격)."
          },
          "captured_at": {
            "type": "string",
            "format": "date-time",
            "description": "캡처 시각 (ISO 8601)."
          },
          "captured_by": {
            "type": "string",
            "enum": [
              "playwright_real",
              "percy_real",
              "chromatic_real",
              "puppeteer_real",
              "cypress_real",
              "simulation"
            ],
            "description": "캡처 도구. ADR-FE-002 §2.3 + ADR-009 §2.2.1 정합. simulation=-5%p 패널티 (no-simulation 정책)."
          },
          "captured_by_version": {
            "type": "string",
            "description": "도구 버전 (예: 'playwright/1.49.0'). 진짜 도구 시 5종 물증 의무."
          },
          "stdout_path": {
            "type": "string",
            "description": "5종 물증 1 — 도구 stdout 로그 경로 (real_tool 시 의무)."
          },
          "stderr_path": {
            "type": "string",
            "description": "5종 물증 2 — 도구 stderr 로그 경로 (real_tool 시 의무)."
          },
          "duration_ms": {
            "type": "integer",
            "minimum": 0,
            "description": "5종 물증 3 — 캡처 소요 ms (real_tool 시 의무)."
          },
          "result_hash": {
            "type": "string",
            "description": "5종 물증 4 — 캡처 결과 종합 hash (real_tool 시 의무). snapshot_hash 와 다를 수 있음 (메타 포함)."
          },
          "reproduction_command": {
            "type": "string",
            "description": "5종 물증 5 — 재현 명령 (real_tool 시 의무). 예: 'npx playwright test --project=chromium login.spec.ts'."
          },
          "simulation_reason": {
            "type": "string",
            "description": "captured_by=simulation 시 의무. 시뮬 사용 사유 명시 (예: '환경 부재 / Stage 4 carry')."
          },
          "a11y_violations": {
            "type": "array",
            "description": "axe-core 진짜 실행 결과 inline (선택 — 별도 a11y deliverable Stage 3-2 신설 시 분리). axe-core JSON 형식 정합.",
            "items": {
              "type": "object",
              "required": ["id", "impact"],
              "properties": {
                "id": {
                  "type": "string",
                  "description": "axe-core rule id (예: 'color-contrast', 'image-alt')."
                },
                "impact": {
                  "type": "string",
                  "enum": ["minor", "moderate", "serious", "critical"],
                  "description": "axe-core impact level."
                },
                "wcag_level": {
                  "type": "string",
                  "enum": ["2.1-A", "2.1-AA", "2.1-AAA", "2.2-A", "2.2-AA", "2.2-AAA"],
                  "description": "WCAG version + level (ADR-FE-005 §2.2.2 baseline 2.1-AA + ratchet 2.2-AA 정합)."
                },
                "nodes": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "target": {
                        "oneOf": [
                          {"type": "string"},
                          {"type": "array", "items": {"type": "string"}}
                        ],
                        "description": "CSS selector 문자열 또는 (iframe/shadow DOM) 문자열 배열."
                      },
                      "html": {"type": "string"},
                      "failure_summary": {"type": "string"}
                    }
                  }
                },
                "help_url": {
                  "type": "string",
                  "description": "axe-core help URL."
                }
              }
            }
          },
          "trust_step": {
            "type": "integer",
            "minimum": 1,
            "maximum": 8,
            "description": "ADR-009 §2.4.2 binary trust path 단계. captured_by=simulation 시 단계 1-2, real_tool 시 단계 5+."
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "captured_by": {
                  "enum": ["playwright_real", "percy_real", "chromatic_real", "puppeteer_real", "cypress_real"]
                }
              }
            },
            "then": {
              "required": ["captured_by_version", "stdout_path", "duration_ms", "reproduction_command"]
            }
          },
          {
            "if": {
              "properties": {
                "captured_by": {"const": "simulation"}
              }
            },
            "then": {
              "required": ["simulation_reason"]
            }
          }
        ]
      }
    },
    "manifest_summary": {
      "type": "object",
      "required": ["total_snapshots", "baseline_count", "drift_count"],
      "properties": {
        "total_snapshots": {"type": "integer", "minimum": 0},
        "baseline_count": {"type": "integer", "minimum": 0},
        "drift_count": {"type": "integer", "minimum": 0},
        "baseline_new_count": {"type": "integer", "minimum": 0},
        "baseline_pending_approval_count": {"type": "integer", "minimum": 0},
        "simulation_count": {
          "type": "integer",
          "minimum": 0,
          "description": "captured_by=simulation 인 snapshot 개수. > 0 시 -5%p 패널티 표기 의무."
        },
        "real_tool_count": {
          "type": "integer",
          "minimum": 0
        },
        "viewport_coverage": {
          "type": "object",
          "description": "viewport_matrix × pages 의 매트릭스 coverage 비율.",
          "additionalProperties": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          }
        },
        "wcag_compliance_summary": {
          "type": "object",
          "description": "axe-core 결과 종합. WCAG level 별 violation 카운트.",
          "properties": {
            "level_2_1_aa_violations": {"type": "integer", "minimum": 0},
            "level_2_2_aa_violations": {"type": "integer", "minimum": 0},
            "ratchet_target": {
              "type": "string",
              "enum": ["2.1-AA", "2.2-AA"],
              "description": "ADR-010 baseline+ratchet 정합 — 현재 ratchet 목표 level."
            }
          }
        }
      }
    },
    "cross_links": {
      "type": "array",
      "description": "Phase 4.5 cross-link 패턴 정합. visual-manifest ↔ ui-spec / state-map / api 의 관계.",
      "items": {
        "type": "object",
        "required": ["from_snapshot", "to_artifact", "to_id", "link_type"],
        "properties": {
          "from_snapshot": {"type": "string"},
          "to_artifact": {
            "type": "string",
            "enum": ["ui-spec", "state-map", "api"]
          },
          "to_id": {"type": "string"},
          "link_type": {
            "type": "string",
            "enum": ["renders", "captures_state", "validates_visual"]
          }
        }
      }
    },
    "baseline_management": {
      "type": "object",
      "description": "baseline 관리 정책 (ADR-FE-002 §2.3 정합).",
      "properties": {
        "storage": {
          "type": "string",
          "enum": ["git_lfs", "baseline_branch", "external_storage", "local_only"],
          "description": "baseline 저장 방식."
        },
        "update_authority": {
          "type": "string",
          "description": "baseline 갱신 승인 권한자 (예: 'designer + PM')."
        },
        "last_baseline_update_at": {
          "type": "string",
          "format": "date-time"
        },
        "last_baseline_update_by": {"type": "string"}
      }
    }
  }
}
