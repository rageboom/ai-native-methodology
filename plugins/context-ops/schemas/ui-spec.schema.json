{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-native-methodology/schemas/ui-spec.schema.json",
  "title": "UI/UX 명세 (UI/UX Specification)",
  "description": "FE 영역 산출물. 페이지/사용자 흐름/컴포넌트 트리/디자인 토큰/사용자 시나리오. FSD + Atomic Design 호환.",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "pages"],
  "properties": {
    "meta": {
      "$ref": "./meta-confidence.schema.json"
    },
    "framework": {
      "type": "string",
      "enum": [
        "react", "vue", "angular", "svelte", "next", "nuxt", "remix",
        "solid", "qwik", "astro",
        "vanilla_js", "jquery_legacy", "jsp_template",
        "unknown"
      ],
      "description": "감지된 FE 프레임워크. v1.4 Stage 3-1 — ADR-FE-001 spectrum Tier 1~4 정합 (Tier 1=react/vue/angular/svelte/solid/qwik/astro/next/nuxt/remix / Tier 2=jquery_legacy / Tier 3=vanilla_js / Tier 4=jsp_template)."
    },
    "design_system_approach": {
      "type": "string",
      "enum": ["atomic_design", "fsd", "feature_based", "mixed", "ad_hoc", "unknown"]
    },
    "pages": {
      "type": "array",
      "description": "페이지 인벤토리",
      "items": {
        "type": "object",
        "required": ["id", "name", "route"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^PAGE-[A-Z0-9_-]+-\\d+$",
            "description": "페이지 ID (예: PAGE-ORDER-001)"
          },
          "name": {
            "type": "string",
            "description": "페이지 이름 (예: '주문 목록')"
          },
          "route": {
            "type": "string",
            "description": "라우트 경로 (예: /orders, /orders/:id)"
          },
          "layout": {
            "type": "string",
            "description": "사용 레이아웃 (예: MainLayout, AuthLayout)"
          },
          "auth_required": {"type": "boolean"},
          "required_roles": {
            "type": "array",
            "items": {"type": "string"}
          },
          "description": {"type": "string"},
          "calls_apis": {
            "type": "array",
            "items": {"type": "string"},
            "description": "호출하는 API operationId 목록 (간단 형식 — 기존 호환 유지)."
          },
          "api_calls": {
            "type": "array",
            "description": "v1.4 Stage 3-1 신규. API 호출 상세 명세 (OpenAPI 3.1 + MSW handler cross-link).",
            "items": {
              "type": "object",
              "required": ["operationId"],
              "properties": {
                "operationId": {
                  "type": "string",
                  "description": "OpenAPI operationId."
                },
                "trigger": {
                  "type": "string",
                  "description": "호출 트리거 (예: 'on_page_mount', 'on_button_click', 'on_form_submit')."
                },
                "http_method": {
                  "type": "string",
                  "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"]
                },
                "request_schema_ref": {
                  "type": "string",
                  "description": "OpenAPI request body schema $ref (예: '#/components/schemas/LoginRequest')."
                },
                "response_schema_ref": {
                  "type": "string",
                  "description": "OpenAPI response schema $ref."
                },
                "msw_handler": {
                  "type": "string",
                  "description": "MSW handler 파일/함수 명 (있을 시). msw-auto-mock 정합."
                }
              }
            }
          },
          "event_handlers": {
            "type": "array",
            "description": "v1.4 Stage 3-1 신규. 페이지 이벤트 핸들러 (state-map cross-link).",
            "items": {
              "type": "object",
              "required": ["event"],
              "properties": {
                "event": {
                  "type": "string",
                  "description": "이벤트명 (예: 'click', 'submit', 'scroll', 'route_enter')."
                },
                "handler_signature": {
                  "type": "string",
                  "description": "핸들러 시그니처 (예: 'handleLogin(e: FormEvent)')."
                },
                "target_state": {
                  "type": "string",
                  "description": "전이 대상 state-map.json machine.state 참조 (예: 'FSM-FE-LOGIN-001:authenticating')."
                },
                "target_api": {
                  "type": "string",
                  "description": "트리거 대상 API operationId (api_calls cross-link)."
                },
                "target_route": {
                  "type": "string",
                  "description": "라우트 전이 대상 (예: '/dashboard')."
                }
              }
            }
          },
          "related_use_cases": {
            "type": "array",
            "items": {"type": "string"},
            "description": "관련 유스케이스 ID"
          },
          "uses_components": {
            "type": "array",
            "items": {"type": "string"},
            "description": "사용 컴포넌트 ID 목록"
          },
          "source_file": {"type": "string"}
        }
      }
    },
    "user_flows": {
      "type": "array",
      "description": "사용자 흐름 (페이지 간 전이)",
      "items": {
        "type": "object",
        "required": ["id", "name", "transitions"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^FLOW-[A-Z0-9_-]+-\\d+$"
          },
          "name": {
            "type": "string",
            "description": "흐름 이름 (예: '주문 생성 흐름')"
          },
          "description": {"type": "string"},
          "entry_page": {"type": "string"},
          "exit_pages": {
            "type": "array",
            "items": {"type": "string"}
          },
          "transitions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["from", "to"],
              "properties": {
                "from": {
                  "type": "string",
                  "pattern": "^PAGE-[A-Z0-9_-]+-\\d+$",
                  "description": "v0.57.0 (FE dogfood cycle4 §8.1 ui-spec-05). 전이 출발 페이지 ID — pages[].id 와 동일 패턴(^PAGE-…)으로 제약해 referential 검증 가능. user_flows = '페이지 간 전이' 이므로 from/to 는 페이지 상태다. 컴포넌트/이벤트 디테일은 trigger 필드에 기록."
                },
                "to": {
                  "type": "string",
                  "pattern": "^PAGE-[A-Z0-9_-]+-\\d+$",
                  "description": "v0.57.0 신규. 전이 도착 페이지 ID — pages[].id 대조 검증 대상."
                },
                "trigger": {
                  "type": "string",
                  "description": "전이 트리거 (예: '로그인 버튼 클릭', '결제 성공'). 컴포넌트(CMP-*) 상호작용/이벤트는 여기에 기술."
                },
                "condition": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "components": {
      "type": "array",
      "description": "컴포넌트 트리 (Atomic Design 또는 FSD)",
      "items": {
        "type": "object",
        "required": ["id", "name", "level"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^CMP-[A-Z0-9_-]+$"
          },
          "name": {"type": "string"},
          "level": {
            "type": "string",
            "enum": [
              "atom",
              "molecule",
              "organism",
              "template",
              "page",
              "feature",
              "entity",
              "shared",
              "widget",
              "legacy_template",
              "legacy_widget",
              "unknown"
            ],
            "description": "Atomic Design (atom~page) 또는 FSD (feature/entity/shared/widget) 레벨. v1.4 Stage 3-1 — legacy_template / legacy_widget 추가 (Tier 2-4 spectrum 정합)."
          },
          "description": {"type": "string"},
          "uses_components": {
            "type": "array",
            "items": {"type": "string"},
            "description": "사용 하위 컴포넌트 ID"
          },
          "props_count": {
            "type": "integer",
            "minimum": 0
          },
          "source_file": {"type": "string"},
          "is_design_system": {
            "type": "boolean",
            "description": "디자인 시스템에 속한 컴포넌트인가"
          },
          "suspense_boundary": {
            "type": "object",
            "description": "v1.4 Stage 3-1 신규. React Suspense / Vue async / Solid Resource 경계 명세.",
            "properties": {
              "enabled": {
                "type": "boolean",
                "description": "본 컴포넌트가 suspense boundary 인지 여부."
              },
              "fallback_component": {
                "type": "string",
                "description": "fallback 컴포넌트 ID (예: 'CMP-LOADING-SPINNER')."
              },
              "error_boundary": {
                "type": "string",
                "description": "error boundary 컴포넌트 ID (있을 시)."
              },
              "lazy_loaded": {
                "type": "boolean",
                "description": "code splitting 적용 여부 (React.lazy / dynamic import)."
              },
              "is_remote_boundary": {
                "type": "boolean",
                "description": "v0.58.0 신규 (FE dogfood cycle5 ui-spec-02). Module-Federation lazy-remote 경계 여부. lazy_loaded(=React.lazy/dynamic import 코드분할)와 구분 — 이것은 별도 빌드/런타임에서 로드되는 MF remote 경계다. remote 가 아닌 평범한 code-split 은 lazy_loaded=true 로 두고 본 필드는 비운다."
              },
              "remote_name": {
                "type": "string",
                "description": "v0.58.0 신규 (FE dogfood cycle5 ui-spec-02). MF remote/exposed module 이름 (예: 'common/Visualizer'). is_remote_boundary=true 일 때 기재."
              }
            }
          }
        }
      }
    },
    "design_tokens": {
      "type": "object",
      "description": "디자인 토큰. v1.4 Stage 3-1 — DTCG Design Tokens Format Module 2025.10 (Final Community Group Report) 정합. ADR-FE-005 §2.2.1 + spec URL 고정.",
      "properties": {
        "spec_source": {
          "type": "string",
          "format": "uri",
          "default": "https://www.designtokens.org/TR/2025.10/format/",
          "description": "v1.4 신규. DTCG spec URL 고정 (cross-check 1차 사료). ADR-FE-005 §2.2.1 W3C Standard ❌ / Community Group Report 명시."
        },
        "spec_status": {
          "type": "string",
          "enum": ["w3c_standard", "community_group_report", "draft", "unknown"],
          "default": "community_group_report",
          "description": "v1.4 신규. DTCG = Community Group Report (Standard 아님). ADR-FE-005 §2.2.1 명시 의무."
        },
        "uses_dtcg_field_names": {
          "type": "boolean",
          "description": "v1.4 신규. $value (required) / $type (optional) / $description (optional) 사용 여부."
        },
        "extracted_from": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "tailwind_config",
              "css_variables",
              "styled_components_theme",
              "figma_export",
              "design_tokens_json",
              "dtcg_format_module",
              "scss_variables"
            ]
          }
        },
        "token_ownership": {
          "type": "string",
          "enum": ["local", "external_package", "mixed", "unknown"],
          "description": "v0.58.0 신규 (FE dogfood cycle5 ui-spec-01). SET 레벨 토큰 소유권 마커. 토큰이 분석 대상 앱에서 정의되는가, 외부 패키지에서 import 되는가. external_package = 외부 디자인시스템(예: @sg/ui-bo foundation/*)에서 정의되고 본 스코프는 소비만 함. mixed = 일부 로컬+일부 외부. (과거 colors._note / colors._token_source_note 자유텍스트로 우회하던 externality 신호의 정식 home — 더 이상 token map value 에 출처를 욱여넣지 말 것.)"
        },
        "external_token_source": {
          "type": "string",
          "description": "v0.58.0 신규 (FE dogfood cycle5 ui-spec-01). 외부 토큰 카탈로그 패키지/경로 (예: '@sg/ui-bo foundation/*') — token_ownership=external_package|mixed 일 때 기재."
        },
        "colors": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        },
        "spacing": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        },
        "typography": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "size": {"type": "string"},
              "weight": {"type": ["string", "integer"]},
              "line_height": {"type": "string"},
              "family": {"type": "string"}
            }
          }
        },
        "shadows": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        },
        "borders": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        },
        "consistency_score": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "디자인 시스템 일관성 점수. 낮으면 안티패턴(AP-FE-XXX)으로 등록"
        }
      }
    },
    "scenarios": {
      "type": "array",
      "description": "사용자 시나리오 (end-to-end 사용자 경험)",
      "items": {
        "type": "object",
        "required": ["id", "name", "steps"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^SCN-[A-Z0-9_-]+-\\d+$"
          },
          "name": {"type": "string"},
          "actor": {
            "type": "string",
            "description": "사용자 유형 (예: '비로그인 사용자', '신규 가입자', '관리자')"
          },
          "preconditions": {
            "type": "array",
            "items": {"type": "string"}
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["step", "action"],
              "properties": {
                "step": {"type": "integer"},
                "action": {
                  "type": "string",
                  "description": "사용자 행동 (예: '상품 상세 페이지 진입')"
                },
                "page": {
                  "type": "string",
                  "description": "관련 페이지 ID"
                },
                "expected_result": {"type": "string"}
              }
            }
          },
          "related_use_cases": {
            "type": "array",
            "items": {"type": "string"}
          },
          "related_pages": {
            "type": "array",
            "items": {"type": "string"}
          },
          "related_apis": {
            "type": "array",
            "items": {"type": "string"}
          },
          "human_review_status": {
            "type": "string",
            "enum": [
              "pending",
              "confirmed",
              "confirmed_with_caveat",
              "needs_planner_review",
              "rejected_planner_note"
            ],
            "description": "기획자 검토 상태. v1.4 Stage 3-1 — confirmed_with_caveat (조건부 승인) / rejected_planner_note (반려 + 사유) 추가."
          },
          "human_review_note": {
            "type": "string",
            "description": "v1.4 Stage 3-1 신규. 기획자 검토 메모 (caveat / rejection 사유 등)."
          }
        }
      }
    }
  }
}
