{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-native-methodology/schemas/architecture.schema.json",
  "title": "아키텍처/의존성 (Architecture)",
  "description": "시스템의 모듈 구조, 계층, 의존성을 표현. 산출물 중 #1.",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "modules", "dependencies"],
  "properties": {
    "meta": {
      "$ref": "./meta-confidence.schema.json"
    },
    "system_name": {
      "type": "string",
      "description": "분석 대상 시스템 이름"
    },
    "architecture_style": {
      "type": "string",
      "enum": ["layered", "hexagonal", "clean", "microservices", "monolith", "modular_monolith", "unknown"],
      "description": "감지된 아키텍처 스타일"
    },
    "modules": {
      "type": "array",
      "description": "모듈/패키지/디렉토리 목록",
      "items": {
        "type": "object",
        "required": ["id", "name", "path", "layer"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^MOD-[A-Z0-9_-]+$",
            "description": "모듈 ID (예: MOD-ORDER, MOD-USER)"
          },
          "name": {
            "type": "string",
            "description": "모듈 이름 (예: 주문, 사용자)"
          },
          "path": {
            "type": "string",
            "description": "소스 경로 (예: src/main/java/com/example/order)"
          },
          "layer": {
            "type": "string",
            "enum": ["presentation", "application", "domain", "infrastructure", "shared", "cross-cutting"],
            "description": "Clean Architecture 기준 계층"
          },
          "responsibility": {
            "type": "string",
            "description": "모듈 책임 (한 줄 요약)"
          },
          "loc": {
            "type": "integer",
            "minimum": 0,
            "description": "Lines of Code"
          },
          "file_count": {
            "type": "integer",
            "minimum": 0
          },
          "related_bounded_context": {
            "type": "string",
            "description": "관련 도메인 경계 (Bounded Context). domain.json의 BC와 매칭"
          }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "description": "모듈 간 의존성 (방향성)",
      "items": {
        "type": "object",
        "required": ["from", "to", "type"],
        "properties": {
          "from": {
            "type": "string",
            "description": "의존하는 모듈 ID"
          },
          "to": {
            "type": "string",
            "description": "의존 받는 모듈 ID"
          },
          "type": {
            "type": "string",
            "enum": ["import", "inheritance", "composition", "api_call", "event", "shared_db"],
            "description": "의존성 종류"
          },
          "weight": {
            "type": "integer",
            "minimum": 1,
            "description": "의존 횟수 (참조 빈도)"
          },
          "violates_layer": {
            "type": "boolean",
            "description": "계층 의존 방향을 위반하는가? (예: domain → infrastructure)"
          },
          "note": {
            "type": "string",
            "description": "의존 edge 사람-눈 설명 라벨 (예: '예외 매핑', '@Public 데코레이터 / 순환'). on-demand 시각화 시 edge 라벨 (ADR-011 / 구 architecture.mermaid edge 라벨 `-.->|...|` 흡수). note=짧은 라벨 / detail=긴 근거. OPTIONAL."
          },
          "detail": {
            "type": "string",
            "description": "edge 코드 근거 상세 (긴 형식). OPTIONAL."
          }
        }
      }
    },
    "circular_dependencies": {
      "type": "array",
      "description": "감지된 순환 의존성 (안티패턴 #6에도 등록됨). v1.1.2 부터 BC 분류 + decision_required 페어 (F-023, ADR-006).",
      "items": {
        "type": "object",
        "required": ["modules", "severity"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^CIRCULAR-[0-9]+$",
            "description": "순환 의존성 ID (예: CIRCULAR-001)"
          },
          "modules": {
            "type": "array",
            "items": {"type": "string"},
            "minItems": 2
          },
          "detection": {
            "type": "object",
            "description": "탐지 단계 메타. 결정적.",
            "properties": {
              "algorithm": {
                "type": "string",
                "enum": ["tarjan_scc", "kosaraju_scc", "other"],
                "default": "tarjan_scc"
              }
            }
          },
          "bc_status": {
            "type": "string",
            "enum": ["same", "different", "undefined"],
            "description": "Bounded Context 분류. same = 같은 BC 내 cross-aggregate / different = 다른 BC 간 양방향 / undefined = BC 미정의 (default). v1.1.2 신설 (ADR-006)."
          },
          "bc_assignment_explicit": {
            "type": "boolean",
            "default": false,
            "description": "코드/문서에 BC 할당이 명시되었는가? false 인 경우 decision_required 권고."
          },
          "documented_decision": {
            "type": "boolean",
            "default": false,
            "description": "ADR 또는 design doc 에 결정 문서가 있는가?"
          },
          "severity": {
            "type": "string",
            "enum": ["high", "medium", "low"],
            "description": "phase-3-arch.md §3.1.1 표 기반 자동 산정. BC 미정의 default = medium."
          },
          "decision_required": {
            "type": "boolean",
            "default": false,
            "description": "Phase 4 진입 전 결정이 필요한가? severity 와 페어링 (ArchUnit FreezingArchRule 패턴)."
          },
          "decision_owner": {
            "type": "string",
            "enum": ["domain_expert", "tech_lead", "architect", "any"],
            "description": "결정 권한자. decision_required=true 시 권고."
          },
          "decision_deadline": {
            "type": "string",
            "description": "결정 마감 (예: 'Phase 4 진입 전')."
          },
          "phase_4_routing": {
            "type": "boolean",
            "default": false,
            "description": "Phase 4 (도메인 모델) 로 라우팅할지 여부. decision_required=true 와 보통 동행."
          },
          "antipattern_id": {
            "type": "string",
            "description": "안티패턴 산출물에서의 ID (AP-ARCH-XXX)"
          },
          "detail": {
            "type": "string",
            "description": "순환 edge 코드 근거 상세 (긴 형식). ecommerce dogfood 산출물이 이미 emit 하던 비공식 필드 명문화. OPTIONAL."
          }
        }
      }
    },
    "external_dependencies": {
      "type": "array",
      "description": "외부 시스템/서비스 의존성 (Phase 4의 5.D 영역에서 추출)",
      "items": {
        "type": "object",
        "required": ["id", "name", "type"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^EXT-[A-Z0-9_-]+$"
          },
          "name": {
            "type": "string",
            "description": "외부 시스템 이름 (예: Toss Payments, AWS SES)"
          },
          "type": {
            "type": "string",
            "enum": ["payment", "sms", "email", "auth", "storage", "messaging", "monitoring", "other"]
          },
          "protocol": {
            "type": "string",
            "enum": ["REST", "gRPC", "GraphQL", "Webhook", "Kafka", "RabbitMQ", "SDK", "other"]
          },
          "called_from_modules": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    }
  }
}
