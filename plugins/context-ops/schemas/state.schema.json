{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-native-methodology/schemas/state.schema.json",
  "title": "Chain Harness Driver State",
  "description": "v2.0 sub-plan-5 — chain harness driver 의 사용자 프로젝트별 영속 state. .ai-context/state.json single source of runtime truth. ADR-CHAIN-005 §2 (atomic write + CAS) + §6 (forward-only migration) 정합. sdlc-4stage-flow.json 의 stages enum 과 정합 (drift-validator --check-state-flow-consistency 가 회귀).",
  "type": "object",
  "required": ["version", "project_id", "current_chain", "stage_progress", "blocked"],
  "additionalProperties": false,
  "properties": {
    "$schema_origin": {
      "type": "string",
      "description": "참조 schema 상대 경로 (관행)"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$",
      "description": "Senior F5 — schema migration policy 의 versioning. forward-only / 직전 1버전 호환. breaking 시 사용자 명시 confirm."
    },
    "project_id": {
      "type": "string",
      "minLength": 1,
      "description": "사용자 프로젝트 식별자 (init 시 결정 — 보통 디렉토리 basename)."
    },
    "current_chain": {
      "type": "string",
      "enum": ["analysis", "discovery", "spec", "plan", "test", "implement", "revisit_pending"],
      "description": "v9.0 6-stage (analysis→discovery→spec→plan→test→implement). sdlc-4stage-flow.json stages 와 정합. drift-validator --check-state-flow-consistency 가 build-time 검증. (planning→discovery 개칭 + plan 신설 / DEC-2026-05-21)"
    },
    "current_phase": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9-]*(\\.\\d+)*$",
      "description": "현 chain 내부의 phase ID. phase-flow node id 체계(kebab + optional .N 인덱스 / 예: input.0 · db-schema.0 · discovery.1 · input-integrate). 구 P*.* 형식도 backward-compat 수용 (F-R2-01: 구 ^P\\d+ pattern 은 phase-flow semantic id 전체와 불일치한 orphan = chain-driver init/CAS write 가 항상 schema-invalid 였음 / DEC-2026-06-12-state-phase-pattern-align)."
    },
    "current_scope": {
      "anyOf": [
        { "type": "null" },
        { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,63}$" }
      ],
      "description": "G3 (R5/R7) — 현재 active scope slug. init --scope <s> 또는 cmdNext 의 manifest sync 대상. D10 single work-unit serial 1차."
    },
    "stage_progress": {
      "type": "object",
      "additionalProperties": false,
      "required": ["analysis", "discovery", "spec", "plan", "test", "implement"],
      "properties": {
        "analysis": { "$ref": "#/$defs/StageRecord" },
        "discovery": { "$ref": "#/$defs/StageRecord" },
        "spec": { "$ref": "#/$defs/StageRecord" },
        "plan": { "$ref": "#/$defs/StageRecord" },
        "test": { "$ref": "#/$defs/StageRecord" },
        "implement": { "$ref": "#/$defs/StageRecord" }
      }
    },
    "last_gate": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["id", "stage", "decision", "decision_at"],
          "additionalProperties": false,
          "properties": {
            "id": {
              "type": "string",
              "enum": ["#0", "#1", "#2", "#3", "#4", "#5"],
              "description": "ADR-CHAIN-002 gate ID — v10.0.0 MAJOR (Phase 4-4') gate 번호 재정렬 (chain 번호 = gate 번호 1:1 INTERNAL CONVENTION). analysis=#0 (DEC-2026-06-06-analysis-exit-gate / pre-chain exit gate) / discovery=#1 / spec=#2 / plan=#3 / test=#4 / implement=#5."
            },
            "stage": {
              "type": "string",
              "enum": ["analysis", "discovery", "spec", "plan", "test", "implement"],
              "description": "v10.0.0 MAJOR (Phase 4-4' / DEC-2026-05-25-axis-a-phase-4-4-prime) — gate #1~#5 = discovery/spec/plan/test/implement. analysis=#0 (DEC-2026-06-06-analysis-exit-gate / pre-chain exit gate). plan stage 본격 hard gate 진입 (v9.3.0 placeholder '#plan' 폐기 + v10.0.0 '#3' 본격)."
            },
            "decision": {
              "type": "string",
              "enum": ["go", "stop", "revisit"]
            },
            "decision_at": {
              "type": "string",
              "format": "date-time"
            },
            "validator_findings": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "critical": { "type": "integer", "minimum": 0 },
                "high": { "type": "integer", "minimum": 0 },
                "medium": { "type": "integer", "minimum": 0 },
                "low": { "type": "integer", "minimum": 0 },
                "info": { "type": "integer", "minimum": 0 }
              }
            },
            "intervention_log_path": {
              "type": "string",
              "description": "ADR-CHAIN-005 §8 / intervention-log.schema.json 정합 — 보통 .ai-context/output/intervention-log.jsonl"
            }
          }
        }
      ]
    },
    "pending_revisit": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["target_stage", "detected_at", "confidence_loc"],
          "additionalProperties": false,
          "properties": {
            "target_stage": {
              "type": "string",
              "enum": ["analysis", "discovery", "spec", "plan", "test"]
            },
            "detected_at": {
              "type": "string",
              "format": "date-time"
            },
            "confidence_loc": {
              "type": "integer",
              "minimum": 0,
              "description": "Senior F4 — non-comment LOC threshold (≥ 5 의무). 미만은 자동 ignore 되어 pending_revisit 에 등록 안 됨."
            },
            "changed_paths": {
              "type": "array",
              "items": { "type": "string" }
            },
            "user_decision": {
              "type": "string",
              "enum": ["pending", "go", "ignore"]
            }
          }
        }
      ]
    },
    "blocked": {
      "type": "boolean",
      "description": "ADR-CHAIN-005 §3 trio (i) — true 시 모든 후속 chain-driver 명령이 비대화형 exit 2 반환."
    },
    "block_reason": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "string",
          "enum": [
            "validator_critical",
            "validator_high",
            "s2_outcome_mismatch",
            "coverage_threshold",
            "layer2_threshold",
            "findings_unverified",
            "evidence_missing",
            "schema_migration_required",
            "state_corrupt",
            "user_stop"
          ]
        }
      ]
    },
    "lock_holder_pid": {
      "anyOf": [
        { "type": "null" },
        { "type": "integer", "minimum": 1 }
      ],
      "description": "Senior F3 — single-writer 가정. 5분 mtime 초과 시 자동 해제."
    },
    "lock_acquired_at": {
      "anyOf": [
        { "type": "null" },
        { "type": "string", "format": "date-time" }
      ]
    },
    "revisit_ignore_globs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Senior F4 — 사용자 학습 누적 ignore globs (`**/*.md`, `**/*.test.*` only-touch 등). chain-revisit-detector confidence score 보정용.",
      "default": []
    },
    "intervention_log_path": {
      "type": "string",
      "description": "프로젝트별 intervention log 경로. 기본 = .ai-context/output/intervention-log.jsonl",
      "default": ".ai-context/output/intervention-log.jsonl"
    }
  },
  "$defs": {
    "StageRecord": {
      "type": "object",
      "required": ["status"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "in_progress", "complete", "blocked", "revisit_pending"]
        },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" },
        "gate_decision": {
          "type": "string",
          "enum": ["go", "stop", "revisit"]
        },
        "git_baseline_sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{7,40}$",
          "description": "Senior F4 — chain stage 진입 시 git HEAD SHA 기록. revisit-detect 가 baseline..HEAD diff 산출 시 deterministic source."
        }
      }
    }
  }
}
