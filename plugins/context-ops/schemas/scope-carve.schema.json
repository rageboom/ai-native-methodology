{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-native-methodology/schemas/scope-carve.schema.json",
  "title": "scope-carve.json — 역공학 scope-carve 3신호 (reference-lens / NOT gate-injected)",
  "description": "역공학 분석 진입 시 대형 코드베이스를 어떤 경계로 쪼갤지 돕는 3 결정론 신호 산출물 (DEC-2026-06-09-scope-carve-3signal-reference-lens). Tarjan SCC(분할 불가 atomic + 추출순서) + Martin Ca/Ce/I(seam·hub·sink 랭킹 / A·D = 입력 부재 abstain) + VCS co-change(git log 이력 logical-coupling mining). trust 모델 (DEC-2026-05-28 §4.2): 어떤 결정적 gate 에도 inject 되지 않는다 — 사용자가 soft gate #0 에서 scope 를 확정한다. 임계치·co-change 파라미터는 soft-gate 노출(렌즈 내부 hardcode ❌).",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "target", "params", "scc", "martin", "co_change", "carve_candidates", "evidence"],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "generated_by", "do_not_edit_manually", "reference_lens", "derived_from", "trust_note", "generated_at"],
      "properties": {
        "schema": { "const": "scope-carve.schema.json" },
        "generated_by": { "const": "scope-carve" },
        "do_not_edit_manually": { "const": true },
        "reference_lens": {
          "const": true,
          "description": "구조적 enforcement — 본 산출물은 reference-lens 이며 어떤 결정적 gate 에도 inject 되지 않는다 (DEC-2026-05-28 §4.2)."
        },
        "derived_from": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["tool", "method"],
            "properties": {
              "tool": { "type": "string" },
              "version": { "type": ["string", "null"] },
              "method": { "type": "string" }
            }
          }
        },
        "trust_note": {
          "type": "string",
          "description": "reference-lens / NOT gate-injected 명시 (trust 모델 enforcement). carve 가 emit 하는 reference finding 은 _base-log-finding 으로 low|medium 만 (gate blocker ❌)."
        },
        "generated_at": { "type": "string", "format": "date-time" }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["architecture_path", "repo_path", "module_count", "dependency_edge_count"],
      "properties": {
        "architecture_path": { "type": "string", "description": "SCC + Martin 입력 (architecture.json)." },
        "repo_path": { "type": ["string", "null"], "description": "co-change 입력 git repo. null = co-change 미실행." },
        "module_count": { "type": "integer", "minimum": 0 },
        "dependency_edge_count": { "type": "integer", "minimum": 0 }
      }
    },
    "params": {
      "type": "object",
      "additionalProperties": false,
      "required": ["co_change", "martin_thresholds"],
      "description": "soft-gate 노출 파라미터 — 'deterministic'은 이 값들이 pin 된 이후에만 성립 (렌즈 내부 hardcode ❌). 사용자가 soft gate #0 에서 조정/확정.",
      "properties": {
        "co_change": {
          "type": "object",
          "additionalProperties": false,
          "required": ["min_support", "min_confidence", "window", "max_transaction_size", "since"],
          "properties": {
            "min_support": { "type": "integer", "minimum": 1, "description": "파일쌍 동시변경 최소 횟수." },
            "min_confidence": { "type": "number", "minimum": 0, "maximum": 1, "description": "조건부 동시변경 비율 최소값." },
            "window": { "type": ["integer", "null"], "minimum": 1, "description": "최근 N commit 으로 제한 (null = 전체 / cold-start·이력 편향 제어)." },
            "max_transaction_size": { "type": "integer", "minimum": 2, "description": "이 파일 수 초과 commit 제외 (tangled commit 결합 inflate 회피)." },
            "since": { "type": ["string", "null"], "description": "git --since 시점 제한 (null = 무제한)." }
          }
        },
        "martin_thresholds": {
          "type": "object",
          "additionalProperties": false,
          "required": ["unstable_instability", "hub_afferent"],
          "description": "role 라벨 부여 임계 = convention (숫자 출력은 결정론이나 cutoff 선택은 사람/휴리스틱). soft gate 위임.",
          "properties": {
            "unstable_instability": { "type": "number", "minimum": 0, "maximum": 1 },
            "hub_afferent": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "scc": {
      "type": "object",
      "additionalProperties": false,
      "required": ["has_cycle", "components", "condensation_order", "note"],
      "description": "Tarjan SCC (O(V+E) / 완전 결정론). multi-node SCC = 분할 불가 atomic 단위 (acyclic cut 으로 cycle 미분리 = 불법 carve 사전 배제). condensation DAG topo = 안전 추출/strangler 순서.",
      "properties": {
        "has_cycle": { "type": "boolean" },
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["index", "members", "size", "is_atomic", "kind", "topo_rank"],
            "properties": {
              "index": { "type": "integer", "minimum": 0, "description": "artifact-local 키 (methodology ID 아님)." },
              "members": { "type": "array", "items": { "type": "string" }, "minItems": 1, "description": "module id 집합." },
              "size": { "type": "integer", "minimum": 1 },
              "is_atomic": { "type": "boolean", "description": "size>1 = 분할 불가 atomic (multi-node cycle)." },
              "kind": { "enum": ["multi_node_cycle", "singleton"] },
              "topo_rank": { "type": "integer", "minimum": 0, "description": "condensation DAG 위상 순위 (의존이 먼저 = 작은 rank)." }
            }
          }
        },
        "condensation_order": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "description": "components[].index 의 위상 정렬 (의존 그래프 topo). 안전 증분 추출은 통상 leaf(가장 많이 의존되는 = 큰 rank)부터 — note 참조."
        },
        "note": { "type": "string" }
      }
    },
    "martin": {
      "type": "array",
      "description": "Martin 컴포넌트 메트릭. Ca/Ce/I = architecture.json deps 에 100% grounded 결정론. A(abstractness)·D(distance) = module 별 abstract/concrete 타입 카운트 필요 → 입력 부재 = abstain(null + not_computable / no-simulation: 추정 ≠ 측정).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["module_id", "afferent", "efferent", "instability", "abstractness", "distance", "abstractness_status", "role"],
        "properties": {
          "module_id": { "type": "string" },
          "afferent": { "type": "integer", "minimum": 0, "description": "Ca — 이 모듈에 들어오는 의존 (in-edge)." },
          "efferent": { "type": "integer", "minimum": 0, "description": "Ce — 이 모듈에서 나가는 의존 (out-edge)." },
          "instability": { "type": ["number", "null"], "minimum": 0, "maximum": 1, "description": "I = Ce/(Ca+Ce). Ca+Ce=0 = null (미정의)." },
          "abstractness": { "type": "null", "description": "abstain — 입력 architecture.json 에 abstract/concrete 타입 카운트 부재." },
          "distance": { "type": "null", "description": "abstain — D=|A+I−1| 는 A 부재로 환원 불가." },
          "abstractness_status": { "const": "not_computable", "description": "no-simulation: abstractness requires per-type abstract/concrete counts absent from architecture.json input." },
          "role": { "enum": ["sink", "hub", "unstable", "balanced", "isolated"], "description": "sink=Ce>0·Ca=0(깨끗 추출) / hub=Ca≥임계(shared kernel, 쪼개면 파편화) / unstable=I≥임계 / isolated=Ca+Ce=0 / balanced=그외." }
        }
      }
    },
    "co_change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "transactions_analyzed", "pairs", "note"],
      "description": "VCS 논리적 결합 (Gall 1998 / ROSE 2004) — git log 이력에서 함께 변경된 파일쌍 mining. 정적 그래프에 직교 (config↔code / iBATIS XML↔DAO 동시편집 = legacy 정적-blind 정조준). 유일 git-only 신호.",
      "properties": {
        "status": { "enum": ["mined", "no_git_history", "not_run"], "description": "no_git_history = repo_path 에 git 이력 없음 (정직 skip / 날조 ❌)." },
        "transactions_analyzed": { "type": "integer", "minimum": 0, "description": "max_transaction_size 필터 통과한 commit 수." },
        "pairs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["a", "b", "support", "confidence_a_given_b", "confidence_b_given_a"],
            "properties": {
              "a": { "type": "string", "description": "파일 경로 (file-level co-change)." },
              "b": { "type": "string" },
              "support": { "type": "integer", "minimum": 1, "description": "a·b 동시변경 commit 수." },
              "confidence_a_given_b": { "type": "number", "minimum": 0, "maximum": 1 },
              "confidence_b_given_a": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        },
        "note": { "type": "string" }
      }
    },
    "carve_candidates": {
      "type": "array",
      "description": "3신호 합성 seam 제안 (evidence-only). 의미·도메인 경계 확정은 soft gate #0 의 사람 — carve 는 구조 신호일 뿐.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["index", "kind", "members", "signals", "rationale", "confidence_note"],
        "properties": {
          "index": { "type": "integer", "minimum": 0 },
          "kind": { "enum": ["atomic_unit", "clean_seam", "hub_warning", "behavioral_cluster"], "description": "atomic_unit=SCC multi-node / clean_seam=Martin sink·고I / hub_warning=Martin hub / behavioral_cluster=co-change." },
          "members": { "type": "array", "items": { "type": "string" }, "minItems": 1, "description": "module id 또는 파일 경로 (behavioral_cluster=파일)." },
          "signals": { "type": "array", "items": { "enum": ["scc", "martin", "co_change"] }, "minItems": 1 },
          "rationale": { "type": "string" },
          "confidence_note": { "type": "string", "description": "구조 신호 한정 / 의미 경계는 human 확정 명시." }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool_version", "invocation_timestamp", "duration_ms", "inputs_hash", "result_hash", "reproduction_command", "git_available", "evidence_trust"],
      "properties": {
        "tool_version": { "type": "string" },
        "invocation_timestamp": { "type": "string", "format": "date-time" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "inputs_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$", "description": "sha256(architecture.json bytes) — 재현성 witness." },
        "result_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$", "description": "sha256(결정론 payload {scc,martin,co_change,carve_candidates}) — timestamp 제외." },
        "reproduction_command": { "type": "string" },
        "git_available": { "type": "boolean" },
        "evidence_trust": {
          "enum": ["real_tool", "simulated"],
          "description": "no-simulation. scope-carve 는 real_tool 만 산출 (Tarjan/Martin/co-change = 진짜 결정론 계산 / simulated 영구 reject)."
        }
      }
    }
  }
}
