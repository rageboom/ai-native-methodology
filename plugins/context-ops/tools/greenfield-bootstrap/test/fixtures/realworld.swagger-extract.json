{
  "scope": "realworld-conduit",
  "spec_source": { "path_or_url": "https://api.realworld.io/api-docs", "fetch_method": "https" },
  "spec_version": "openapi-3.0",
  "info": {
    "title": "RealWorld Conduit API",
    "version": "1.0.0",
    "description": "Conduit (RealWorld) — Medium-clone backend. greenfield via swagger 채널 dogfood."
  },
  "servers": [
    { "url": "https://api.realworld.io/api", "description": "production" }
  ],
  "endpoints": [
    {
      "path": "/users/login",
      "method": "post",
      "operation_id": "Login",
      "summary": "Existing user login",
      "tags": ["User and Authentication"],
      "request_body_schema_ref": "LoginUserRequest",
      "responses": {
        "200": { "description": "OK", "schema_ref": "UserResponse" },
        "401": { "description": "Unauthorized" },
        "422": { "description": "Unexpected error", "schema_ref": "GenericErrorModel" }
      }
    },
    {
      "path": "/users",
      "method": "post",
      "operation_id": "CreateUser",
      "summary": "Register a new user",
      "tags": ["User and Authentication"],
      "request_body_schema_ref": "NewUserRequest",
      "responses": {
        "201": { "description": "Created", "schema_ref": "UserResponse" },
        "422": { "description": "Unexpected error", "schema_ref": "GenericErrorModel" }
      }
    },
    {
      "path": "/articles/{slug}",
      "method": "get",
      "operation_id": "GetArticle",
      "summary": "Get an article by slug",
      "tags": ["Articles"],
      "parameters": [
        { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "responses": {
        "200": { "description": "OK", "schema_ref": "SingleArticleResponse" }
      }
    }
  ],
  "schemas": {
    "LoginUserRequest": {
      "type": "object",
      "required": ["user"],
      "properties": {
        "user": {
          "type": "object",
          "required": ["email", "password"],
          "properties": {
            "email": { "type": "string", "format": "email" },
            "password": { "type": "string", "format": "password" }
          }
        }
      }
    },
    "NewUserRequest": {
      "type": "object",
      "required": ["user"],
      "properties": {
        "user": {
          "type": "object",
          "required": ["username", "email", "password"],
          "properties": {
            "username": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "password": { "type": "string", "format": "password" }
          }
        }
      }
    },
    "UserResponse": {
      "type": "object",
      "required": ["user"],
      "properties": {
        "user": {
          "type": "object",
          "required": ["email", "token", "username"],
          "properties": {
            "email": { "type": "string" },
            "token": { "type": "string" },
            "username": { "type": "string" },
            "bio": { "type": "string" },
            "image": { "type": "string" }
          }
        }
      }
    },
    "SingleArticleResponse": {
      "type": "object",
      "required": ["article"],
      "properties": {
        "article": { "type": "object" }
      }
    },
    "GenericErrorModel": {
      "type": "object",
      "required": ["errors"],
      "properties": {
        "errors": {
          "type": "object",
          "required": ["body"],
          "properties": {
            "body": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    }
  }
}
