{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-native-methodology/schemas/rules.schema.json",
  "title": "비즈니스 규칙 (Business Rules)",
  "description": "Given/When/Then 형식. Phase 4의 4영역(DB/FE/설정/외부)에서 추출된 규칙들 통합. 신뢰도 낮으므로 사람 검토 필수.",
  "type": "object",
  "required": ["meta", "rules"],
  "properties": {
    "meta": {
      "$ref": "./meta-confidence.schema.json"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "given", "when", "then"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^BR-[A-Z0-9_-]+-\\d+$",
            "description": "규칙 ID (예: BR-ORDER-007)"
          },
          "name": {
            "type": "string",
            "description": "규칙 짧은 이름 (예: '성인 인증 후 주류 주문')"
          },
          "description": {
            "type": "string",
            "description": "상세 설명"
          },
          "category": {
            "type": "string",
            "enum": [
              "validation",
              "policy",
              "calculation",
              "authorization",
              "workflow",
              "integration",
              "fe_validation",
              "fe_authorization",
              "fe_a11y",
              "fe_i18n"
            ],
            "description": "규칙 분류. v1.4 Stage 3-2 — FE 영역 4종 추가 (fe_validation / fe_authorization / fe_a11y / fe_i18n). state-map.json `validates` cross-link 정합 + a11y-spec / i18n-spec cross-link."
          },
          "bounded_context": {
            "type": "string",
            "description": "관련 도메인 경계 ID (예: BC-ORDER)"
          },
          "given": {
            "type": "array",
            "items": {"type": "string"},
            "description": "전제 조건 (자연어)",
            "minItems": 1
          },
          "when": {
            "type": "array",
            "items": {"type": "string"},
            "description": "발동 조건 (자연어)",
            "minItems": 1
          },
          "then": {
            "type": "array",
            "items": {"type": "string"},
            "description": "결과 (자연어)",
            "minItems": 1
          },
          "rationale": {
            "type": "string",
            "description": "규칙의 근거 (법규, 정책, 도메인 합의 등). 코드만으로는 추출 어려움."
          },
          "extracted_from_area": {
            "type": "string",
            "enum": ["5.A_db_logic", "5.B_fe_logic", "5.C_config_policy", "5.D_external_dep", "multiple"],
            "description": "Phase 4 어느 영역에서 추출되었는가"
          },
          "source_format": {
            "type": "string",
            "enum": [
              "zod",
              "yup",
              "joi",
              "react_hook_form",
              "class_validator",
              "ajv",
              "vest",
              "manual",
              "spring_validator",
              "javax_validation"
            ],
            "description": "v1.4 Stage 7-pre 신규. fe_validation BR 의 추출 source library (form-validation-spec.schema.json 정합). category=fe_validation 시 권장. BE 영역 (spring_validator / javax_validation) 도 cover."
          },
          "auto_extracted": {
            "type": "boolean",
            "description": "v1.4 Stage 7-pre 신규. true 시 form-validation-spec 또는 class-validator decorator 등으로 부터 자동 추출됨. false 시 사람 작성 / LLM 추론."
          },
          "auto_extraction_source_id": {
            "type": "string",
            "description": "v1.4 Stage 7-pre 신규. auto_extracted=true 시 source 산출물 ID (예: F-VAL-LOGIN-EMAIL-001)."
          },
          "source_evidence": {
            "type": "array",
            "description": "추출 근거 (파일 + 라인)",
            "items": {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "code_validation",
                    "code_condition",
                    "orm_constraint",
                    "sql_case",
                    "sql_where",
                    "stored_procedure",
                    "db_check_constraint",
                    "config_value",
                    "fe_validation_schema",
                    "fe_permission_branch",
                    "auth_expression",
                    "external_call",
                    "comment",
                    "test_assertion"
                  ]
                },
                "file": {"type": "string"},
                "line": {"type": "integer"},
                "snippet": {
                  "type": "string",
                  "description": "근거 코드 스니펫"
                }
              }
            }
          },
          "related_use_cases": {
            "type": "array",
            "items": {"type": "string"}
          },
          "related_api_operations": {
            "type": "array",
            "items": {"type": "string"},
            "description": "관련 API operationId"
          },
          "related_entities": {
            "type": "array",
            "items": {"type": "string"}
          },
          "related_db_tables": {
            "type": "array",
            "items": {"type": "string"}
          },
          "related_pages": {
            "type": "array",
            "items": {"type": "string"},
            "description": "관련 UI 페이지 ID (특히 5.B에서 추출된 규칙)"
          },
          "duplicates": {
            "type": "array",
            "items": {"type": "string"},
            "description": "중복 검출된 다른 규칙 ID (FE/BE에 같은 규칙이 박힌 경우)"
          },
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 0.98,
            "description": "이 규칙의 추출 신뢰도. cap 0.98 (ADR-003 §6.1). 0.7 이상이어도 사람 검토 권장."
          },
          "human_review_status": {
            "type": "string",
            "enum": ["pending", "in_review", "approved", "rejected", "modified"],
            "default": "pending"
          },
          "human_review_note": {
            "type": "string",
            "description": "검토자 노트"
          },
          "is_active": {
            "type": "boolean",
            "description": "현재 활성 규칙인가? (deprecated 코드일 수도 있음)",
            "default": true
          },
          "deprecation_note": {
            "type": "string",
            "description": "비활성 규칙인 경우 사유"
          },
          "tags": {
            "type": "array",
            "items": {"type": "string"},
            "description": "검색용 태그 (예: ['주류', '연령', '법규'])"
          }
        }
      }
    },
    "rule_conflicts": {
      "type": "array",
      "description": "규칙 간 모순/중복 발견 (자동 또는 검토 시 추가)",
      "items": {
        "type": "object",
        "properties": {
          "rule_ids": {
            "type": "array",
            "items": {"type": "string"},
            "minItems": 2
          },
          "type": {
            "type": "string",
            "enum": ["duplicate", "contradiction", "subsumption", "inconsistent_threshold"]
          },
          "description": {"type": "string"},
          "resolution": {
            "type": "string",
            "enum": ["pending", "merged", "kept_separate", "deprecated_one"]
          }
        }
      }
    }
  }
}
