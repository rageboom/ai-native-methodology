{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-native-methodology/schemas/i18n-spec.schema.json",
  "title": "I18n Spec (ICU MF1 stable + MF2 spec stable / runtime preview)",
  "description": "Deliverable #11 (v1.4 신설). 정적 분석 가능 i18n 검증. ICU MessageFormat 1 (stable) + MF2 (runtime Technical Preview / MF1 폴백 의무). ADR-FE-005 §2.2.3 정합.",
  "x-spec-source": {
    "icu_mf1": "https://unicode-org.github.io/icu/userguide/format_parse/messages/",
    "icu_mf2": "https://unicode-org.github.io/icu/userguide/format_parse/messages/mf2.html",
    "cldr": "https://cldr.unicode.org/",
    "bcp_47": "https://www.rfc-editor.org/rfc/rfc5646"
  },
  "x-status-note": {
    "mf1_status": "stable",
    "mf2_spec_status": "stable (Unicode LDML 47+)",
    "mf2_runtime_status": "Technical Preview (ICU4J / ICU4C 일부 default function / u: namespace = Draft)",
    "mf1_fallback_required_when_mf2_used": true,
    "ratification_source": "ADR-FE-005 §2.2.3 cross-check 권고 #3"
  },
  "type": "object",
  "required": ["meta", "default_locale", "supported_locales", "resources", "summary"],
  "properties": {
    "meta": { "$ref": "./meta-confidence.schema.json" },
    "default_locale": {
      "type": "string",
      "description": "BCP 47 locale tag (예: 'ko-KR')."
    },
    "supported_locales": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "BCP 47 locale tag 배열."
    },
    "runtime": {
      "type": "object",
      "required": ["library"],
      "properties": {
        "library": {
          "type": "string",
          "enum": [
            "icu4j",
            "icu4c",
            "formatjs",
            "react-intl",
            "i18next",
            "vue-i18n",
            "@angular/localize",
            "lingui",
            "next-intl",
            "polyglot",
            "messageformat",
            "custom",
            "unknown"
          ]
        },
        "library_version": { "type": "string" },
        "supports_mf1": { "type": "boolean" },
        "supports_mf2": {
          "type": "boolean",
          "description": "MF2 runtime 지원 여부. ICU4J/ICU4C = Technical Preview (ADR-FE-005 §2.2.3)."
        },
        "mf1_fallback_present": {
          "type": "boolean",
          "description": "MF2 사용 시 의무 — MF1 폴백 병기 여부. supports_mf2=true & mf1_fallback_present=false → finding 등록."
        }
      }
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "translations"],
        "properties": {
          "key": {
            "type": "string",
            "description": "translation key (예: 'auth.login.title')."
          },
          "namespace": {
            "type": "string",
            "description": "feature / domain namespace (선택)."
          },
          "translations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["locale", "message", "format"],
              "properties": {
                "locale": {"type": "string", "description": "BCP 47 tag."},
                "message": {"type": "string"},
                "format": {
                  "type": "string",
                  "enum": ["icu_mf1", "icu_mf2", "plain", "interpolation_only"]
                },
                "uses_plural_rule": {"type": "boolean"},
                "uses_select_rule": {"type": "boolean"},
                "uses_gender_select": {
                  "type": "boolean",
                  "description": "영문만 gender select / locale 별 차이 (예: 한국어 무성). finding 의무."
                },
                "uses_date_format": {"type": "boolean"},
                "uses_number_format": {"type": "boolean"},
                "icu_mf2_features_used": {
                  "type": "array",
                  "description": "MF2 사용 시 features 명시. default function (Draft) 사용 시 finding 의무.",
                  "items": {
                    "type": "string",
                    "enum": ["plural_match", "select_match", "number_function", "date_function", "u_namespace_draft"]
                  }
                }
              }
            }
          },
          "source_files": {
            "type": "array",
            "items": {"type": "string"}
          },
          "cross_links": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["to_artifact", "to_id", "link_type"],
              "properties": {
                "to_artifact": {
                  "type": "string",
                  "enum": ["ui-spec", "state-map", "antipatterns"]
                },
                "to_id": {"type": "string"},
                "link_type": {
                  "type": "string",
                  "enum": ["shown_on", "displayed_in_state", "registers_as_antipattern"]
                }
              }
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total_keys", "missing_per_locale"],
      "properties": {
        "total_keys": {"type": "integer", "minimum": 0},
        "total_translations": {"type": "integer", "minimum": 0},
        "missing_per_locale": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        },
        "mf2_used": {"type": "boolean"},
        "mf1_fallback_present": {
          "type": "boolean",
          "description": "MF2 사용 시 본 필드 true 의무 (ADR-FE-005 §2.2.3)."
        },
        "captured_by": {
          "type": "string",
          "enum": ["icu_real", "formatjs_real", "i18next_real", "static_extraction", "simulation"],
          "description": "static_extraction = source 코드만 read (정적). 진짜 runtime 검증은 simulation 아님."
        },
        "simulation_reason": {"type": "string"}
      },
      "allOf": [
        {
          "if": {
            "properties": { "mf2_used": {"const": true} }
          },
          "then": {
            "required": ["mf1_fallback_present"],
            "description": "MF2 사용 시 mf1_fallback_present 의무 (ADR-FE-005 §2.2.3)."
          }
        }
      ]
    }
  }
}
