{
  "$schema_origin": "ai-native-methodology/schemas/state-map.schema.json ( Stage 3-1 신설 / SCXML 1.0 + XState v5 호환)",
  "meta": {
    "poc_id": "poc-04-mini",
    "phase": "ui",
    "captured_at": "2026-05-02",
    "captured_by": "real",
    "framework_neutral_format": " XState JSON 단일 진실 + SCXML subset compatible (states/transitions/events/guards)",
    "scxml_xstate_round_trip_compatibility": " 부분 (research Q9 출처 부재 — 본 모델은 framework-neutral spec 만 사용)"
  },
  "five_truths_coverage": {
    "1_server_cache": "✅ 본 mini scope (TanStack React Query)",
    "2_client_global": "△ 약식 (auth-storage / userContext middleware)",
    "3_url": "✅ 본 mini scope (HomeSearchParams + paths)",
    "4_form": "✅ 본 mini scope (login + comment-create)",
    "5_dom": "△ 부분 (use-fake-progress / optimistic count computation)"
  },
  "state_machines": [
    {
      "id": "SM-LOGIN-FORM",
      "purpose": " 진실 #4 form state — Login form submit lifecycle",
      "five_truths": ["form"],
      "binding_component": "LoginPage (PAGE-LOGIN)",
      "initial_state": "idle",
      "context": {
        "validationErrors": "ErrorFields | null",
        "authError": "string | null"
      },
      "states": {
        "idle": {
          "on": {
            "SUBMIT": "validating"
          }
        },
        "validating": {
          "invoke": {
            "src": "validateSchema (Zod LoginBody)",
            "onDone": "submitting",
            "onError": "validation-error"
          }
        },
        "submitting": {
          "invoke": {
            "src": "POST /users/login",
            "onDone": "success",
            "onError": "auth-error"
          }
        },
        "validation-error": {
          "on": {
            "RETRY": "validating"
          }
        },
        "auth-error": {
          "on": {
            "RETRY": "validating"
          }
        },
        "success": {
          "type": "final",
          "actions": ["setToken", "setQueryData(currentUser)", "redirect(/settings)"]
        }
      }
    },
    {
      "id": "SM-FEED-NAVIGATION",
      "purpose": " 진실 #3 URL state — Home feed switch (global / personal / tag)",
      "five_truths": ["url"],
      "binding_component": "HomePage § HomeFeed",
      "initial_state": "global",
      "context": {
        "limit": "number (1~100, default 10)",
        "offset": "number (≥0, default 0)",
        "feed": "'personal' | undefined",
        "tag": "string | undefined"
      },
      "states": {
        "global": {
          "on": {
            "SWITCH_PERSONAL": {
              "target": "personal",
              "guard": "isAuthenticated"
            },
            "SELECT_TAG": "tag"
          }
        },
        "personal": {
          "on": {
            "SWITCH_GLOBAL": "global",
            "SELECT_TAG": "tag",
            "AUTH_LOST": {
              "target": "global",
              "actions": ["normalize_url"]
            }
          }
        },
        "tag": {
          "on": {
            "SWITCH_GLOBAL": "global",
            "SWITCH_PERSONAL": {
              "target": "personal",
              "guard": "isAuthenticated"
            },
            "CLEAR_TAG": "global"
          }
        }
      },
      "url_state_validation": {
        "source": " Zod-mini (home.state.ts) — PaginationSchema + HomeArticleFilterSchema",
        "br_auto_extraction_target": " deliverable 14 § URL state validation BR ( 신규 패턴)"
      }
    },
    {
      "id": "SM-FAVORITE-TOGGLE",
      "purpose": " optimistic update — favorite article ( 진실 #1 server cache + #5 DOM)",
      "five_truths": ["server_cache", "dom"],
      "binding_component": ["HomeFavoriteButton", "FavoriteArticleButton (article)"],
      "initial_state": "inactive",
      "context": {
        "favoritesCount": "number",
        "optimisticOperation": "'favorite' | 'unfavorite' | undefined"
      },
      "states": {
        "inactive": {
          "on": {
            "FAVORITE": {
              "target": "pending-favorite",
              "guard": "isAuthenticated",
              "actions": ["set_optimistic('favorite')"]
            }
          }
        },
        "active": {
          "on": {
            "UNFAVORITE": {
              "target": "pending-unfavorite",
              "actions": ["set_optimistic('unfavorite')"]
            }
          }
        },
        "pending-favorite": {
          "invoke": {
            "src": "POST /articles/:slug/favorite-toggle (operation=favorite)",
            "onDone": "active",
            "onError": {
              "target": "inactive",
              "actions": ["clear_optimistic", "rollback"]
            }
          }
        },
        "pending-unfavorite": {
          "invoke": {
            "src": "POST /articles/:slug/favorite-toggle (operation=unfavorite)",
            "onDone": "inactive",
            "onError": {
              "target": "active",
              "actions": ["clear_optimistic", "rollback"]
            }
          }
        }
      },
      "validation_br": {
        "operation_enum": ["favorite", "unfavorite"],
        "br_auto_extraction_target": " deliverable 14 § FormData operation validation"
      }
    },
    {
      "id": "SM-FOLLOW-TOGGLE",
      "purpose": " optimistic update — follow author",
      "five_truths": ["server_cache", "dom"],
      "binding_component": "FollowAuthorButton (article)",
      "initial_state": "not-following",
      "context": {
        "username": "string",
        "optimisticOperation": "'follow' | 'unfollow' | undefined"
      },
      "states": {
        "not-following": {
          "on": {
            "FOLLOW": {
              "target": "pending-follow",
              "guard": "isAuthenticated",
              "actions": ["set_optimistic('follow')"]
            }
          }
        },
        "following": {
          "on": {
            "UNFOLLOW": {
              "target": "pending-unfollow",
              "actions": ["set_optimistic('unfollow')"]
            }
          }
        },
        "pending-follow": {
          "invoke": {
            "src": "POST /article/:slug/follow-toggle (operation=follow, username=X)",
            "onDone": "following",
            "onError": {
              "target": "not-following",
              "actions": ["clear_optimistic", "rollback"]
            }
          }
        },
        "pending-unfollow": {
          "invoke": {
            "src": "POST /article/:slug/follow-toggle (operation=unfollow, username=X)",
            "onDone": "not-following",
            "onError": {
              "target": "following",
              "actions": ["clear_optimistic", "rollback"]
            }
          }
        }
      },
      "validation_br": {
        "operation_enum": ["follow", "unfollow"],
        "username_required": true,
        "username_non_empty": true
      }
    },
    {
      "id": "SM-COMMENT-FORM",
      "purpose": " 진실 #4 form — Comment create lifecycle with reset key",
      "five_truths": ["form"],
      "binding_component": "CreateCommentForm",
      "initial_state": "idle",
      "context": {
        "body": "string",
        "errors": "ErrorFields | null",
        "resetKey": "string"
      },
      "states": {
        "idle": {
          "on": {
            "SUBMIT": {
              "target": "submitting",
              "guard": "body.length > 0"
            }
          }
        },
        "submitting": {
          "invoke": {
            "src": "POST /article/:slug/comments",
            "onDone": {
              "target": "idle",
              "actions": ["update_resetKey", "form_remount ( React key pattern)"]
            },
            "onError": "error"
          }
        },
        "error": {
          "on": {
            "RETRY": "submitting",
            "EDIT": "idle"
          }
        }
      },
      "validation_br": {
        "body_required": true,
        "body_non_empty": true,
        "html5_native_required": true
      }
    }
  ],
  "summary": {
    "state_machines_count": 5,
    "five_truths_coverage": {
      "server_cache": 2,
      "client_global": 0,
      "url": 1,
      "form": 2,
      "dom": 2
    },
    "optimistic_update_machines": 2,
    "framework_neutrality": " 100% (모든 SM = SCXML+XState 호환 형식 / React 관용구 0)",
    "ir_react_idioms_in_spec": 0,
    "validation_br_extracted": 9
  }
}
