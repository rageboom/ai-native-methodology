{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-native-methodology/schemas/antipatterns.schema.json",
  "title": "안티패턴 카탈로그 (Antipatterns)",
  "description": "재구현 시 회피해야 할 후보 목록. 비난 톤이 아닌 '회피 후보' 톤으로 작성.",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "antipatterns"],
  "properties": {
    "meta": {
      "$ref": "./meta-confidence.schema.json"
    },
    "antipatterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category", "name", "severity"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^AP-[A-Z]+-\\d+$",
            "description": "안티패턴 ID (예: AP-DB-007, AP-ARCH-003)"
          },
          "category": {
            "type": "string",
            "enum": [
              "ARCH",
              "DB",
              "DOMAIN",
              "API",
              "FE",
              "CONFIG",
              "EXTERNAL",
              "SECURITY",
              "PERFORMANCE",
              "TESTABILITY",
              "MAINTAINABILITY"
            ],
            "description": "카테고리"
          },
          "name": {
            "type": "string",
            "description": "짧은 이름 (예: '비즈니스 정책이 SQL CASE에 박힘')"
          },
          "description": {
            "type": "string",
            "description": "상세 설명"
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "info"],
            "description": "심각도"
          },
          "why_avoid": {
            "type": "string",
            "description": "왜 회피해야 하는가 (재구현 관점)"
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["file"],
              "properties": {
                "file": {"type": "string"},
                "line": {"type": "integer"},
                "snippet": {"type": "string"},
                "context_note": {"type": "string"}
              }
            }
          },
          "occurrences": {
            "type": "integer",
            "minimum": 1,
            "description": "발견 횟수 (같은 패턴이 여러 곳에 있으면)"
          },
          "recommended_alternative": {
            "type": "string",
            "description": "권장 대안 (재구현 시 어떻게 바꿀지)"
          },
          "migration_advice": {
            "type": "string",
            "description": "신규 시스템 구축 시 회피 가이드. v1.2.0 신설 (묶음 P / DEC-2026-04-29-안티패턴-마이그레이션-가이드 α). recommended_alternative 와 별도 — 'how to avoid in greenfield' 관점."
          },
          "related_rules_to_extract": {
            "type": "array",
            "items": {"type": "string"},
            "description": "이 안티패턴 자리에서 추출되어야 하는 비즈니스 규칙 ID들"
          },
          "related_modules": {
            "type": "array",
            "items": {"type": "string"}
          },
          "detected_by": {
            "type": "string",
            "enum": ["static_analysis", "llm_inference", "pattern_match", "human_review"],
            "description": "감지 방식"
          },
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 0.98,
            "description": "이 안티패턴 검출의 신뢰도. cap 0.98 (ADR-003 §6.1)."
          },
          "human_review_status": {
            "type": "string",
            "enum": ["pending", "confirmed", "false_positive", "wont_fix"],
            "default": "pending"
          },
          "tags": {
            "type": "array",
            "items": {"type": "string"}
          },
          "formal_spec_links": {
            "type": "object",
            "description": "Phase 4.5 형식 명세 cross-link (ADR-008 이중 렌더링 + Phase 4.5 본질 가치). 도입: v1.2.3 (선택). 부분 의무화: v1.3.1 후속 commit `3af78e5` (2026-05-01) — DOMAIN / API / FE 카테고리 의무 (allOf if-then 참조). 적용 범위: v1.4 신규 PoC 부터. v1.3.x release 시점 PoC #01~03 산출물은 release 보존 (재검증 없음). 상세 결정 근거: deliverables/6-antipatterns.md §5.6 + §8.1 단일 PoC 과적합 회피 정합.",
            "properties": {
              "decision_tables": {
                "type": "array",
                "items": {"type": "string"},
                "description": "관련 BR decision-table 파일 (예: ../formal-spec/decision-tables/BR-USER-DELETE-AUTH-001.md)"
              },
              "state_machines": {
                "type": "array",
                "items": {"type": "string"},
                "description": "관련 state-machine 파일 (예: ../formal-spec/state-machines/User.json)"
              },
              "sequence_diagrams": {
                "type": "array",
                "items": {"type": "string"},
                "description": "관련 sequence-diagram 파일"
              },
              "invariants": {
                "type": "array",
                "items": {"type": "string"},
                "description": "관련 invariant 파일 (예: ../formal-spec/invariants/User.ts)"
              }
            }
          }
        },
        "allOf": [
          {
            "$comment": "v1.4 격상 — formal_spec_links 카테고리별 conditional required. DOMAIN / API / FE 카테고리는 BR/state-machine 직결 → 의무. ARCH / DB / PERFORMANCE / SECURITY / 그 외는 BR 무관 → 선택 (강제 시 boilerplate 양산). PoC #03 36% 자발적 입증 + §8.1 단일 PoC 과적합 회피 정합. 적용 시점 = v1.4 신규 PoC 부터 (기존 PoC #01~03 산출물은 v1.3.x release 보존).",
            "if": {
              "properties": {
                "category": {
                  "enum": ["DOMAIN", "API", "FE"]
                }
              }
            },
            "then": {
              "required": ["formal_spec_links"]
            }
          }
        ]
      }
    },
    "summary": {
      "type": "object",
      "description": "카테고리별 요약 통계",
      "properties": {
        "by_category": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "count": {"type": "integer"},
              "by_severity": {
                "type": "object",
                "additionalProperties": {"type": "integer"}
              }
            }
          }
        },
        "total_count": {"type": "integer"},
        "critical_count": {"type": "integer"}
      }
    },
    "checklist_file": {
      "type": "string",
      "description": "사람이 보기 쉬운 체크리스트 마크다운 파일 경로 (avoid-list.md)"
    }
  }
}
