{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-native-methodology/schemas/inventory.schema.json",
  "title": "인벤토리 (Inventory)",
  "description": "Phase 1 (init) 산출물. 분석 대상 레포의 구조·스택·규모. v1.1.2 신설 (F-007). schema = SoT, phase-1-init.md §4.2 는 reference sample.",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "repo", "stack"],
  "properties": {
    "meta": {
      "$ref": "./meta-confidence.schema.json"
    },
    "repo": {
      "type": "object",
      "required": ["name", "total_files"],
      "properties": {
        "name": {
          "type": "string",
          "description": "레포명"
        },
        "total_files": {
          "type": "integer",
          "minimum": 0
        },
        "total_loc": {
          "type": "integer",
          "minimum": 0,
          "description": "전체 LOC. extraction_method 가 deterministic (cloc/tokei) 일 때만 정확. heuristic (byte/35) 추정 시 meta.warnings 에 명시 의무."
        },
        "loc_extraction_method": {
          "type": "string",
          "enum": ["deterministic", "heuristic_byte_per_35", "estimation", "unknown"],
          "description": "LOC 산출 방법. F-009 결정성 축. heuristic 또는 estimation 인 경우 meta.warnings 동반."
        },
        "primary_languages": {
          "type": "array",
          "description": "주요 언어 분포. byte 기준이 결정적, LOC 기준은 method 에 따라 다름.",
          "items": {
            "type": "object",
            "required": ["lang"],
            "properties": {
              "lang": {
                "type": "string",
                "description": "언어 식별자 (예: typescript, java, python)"
              },
              "bytes": {
                "type": "integer",
                "minimum": 0,
                "description": "byte 기준 (Linguist/GitHub 표준). 결정적."
              },
              "loc": {
                "type": "integer",
                "minimum": 0
              },
              "pct": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              }
            }
          }
        }
      }
    },
    "stack": {
      "type": "object",
      "description": "감지된 기술 스택. backend/frontend/etc 분리.",
      "properties": {
        "backend": {
          "$ref": "#/$defs/stackTier"
        },
        "frontend": {
          "$ref": "#/$defs/stackTier"
        },
        "mobile": {
          "$ref": "#/$defs/stackTier"
        },
        "infra": {
          "$ref": "#/$defs/stackTier"
        }
      }
    },
    "architecture_style_candidates": {
      "type": "array",
      "maxItems": 3,
      "description": "아키텍처 스타일 후보. Phase 1 단계에서는 LLM 추론이라 cap 0.7 권장. 최종 결정은 Phase 3 으로 유보.",
      "items": {
        "type": "object",
        "required": ["style", "confidence"],
        "properties": {
          "style": {
            "type": "string",
            "enum": ["layered", "hexagonal", "clean", "microservices", "monolith", "modular_monolith", "unknown"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 0.7,
            "description": "Phase 1 한계로 cap 0.7. 최종 분류는 Phase 3."
          },
          "evidence": {
            "type": "array",
            "items": {"type": "string"},
            "description": "감지 단서 (예: controller/service/repository 패턴)"
          }
        }
      }
    },
    "modules_for_priority_analysis": {
      "type": "array",
      "description": "후속 phase 우선 분석 권장 모듈. LOC/파일 수 기준 큰 모듈 또는 핵심 도메인 추정.",
      "items": {
        "type": "object",
        "required": ["path", "reason"],
        "properties": {
          "path": {
            "type": "string",
            "description": "소스 경로"
          },
          "reason": {
            "type": "string",
            "description": "추천 사유"
          },
          "loc": {
            "type": "integer",
            "minimum": 0
          },
          "file_count": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "directory_tree_extraction": {
      "type": "object",
      "description": "디렉토리 트리 산출 메타. F-009 환경 caveat (Trees API truncation 위험 등).",
      "properties": {
        "method": {
          "type": "string",
          "enum": ["filesystem", "git_trees_api", "raw_fetch", "other"]
        },
        "truncated": {
          "type": "boolean",
          "default": false,
          "description": "API 한계 (예: GitHub Trees API 7MB/100k entries) 로 truncate 되었는가?"
        },
        "total_entries": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "$defs": {
    "stackTier": {
      "type": "object",
      "description": "스택 한 계층 (backend/frontend 등)",
      "properties": {
        "language": {
          "type": "string",
          "description": "주 언어 (버전 포함, 예: 'Java 17')"
        },
        "framework": {
          "type": "string",
          "description": "주 프레임워크 (버전 포함, 예: 'Spring Boot 3.2.x')"
        },
        "orm": {
          "type": "array",
          "description": "감지된 ORM 목록 (혼재 가능)",
          "items": {
            "type": "object",
            "required": ["name", "confidence"],
            "properties": {
              "name": {
                "type": "string",
                "description": "예: 'JPA/Hibernate', 'MyBatis', 'Prisma'"
              },
              "confidence": {
                "type": "number",
                "minimum": 0.0,
                "maximum": 1.0
              },
              "evidence": {
                "type": "array",
                "items": {"type": "string"}
              }
            }
          }
        },
        "db": {
          "type": "string",
          "description": "감지된 DB. 추정인 경우 '(추정)' 명시."
        },
        "state_management": {
          "type": "string",
          "description": "상태관리 (frontend 한정, 예: 'Redux Toolkit', 'Zustand')"
        },
        "ui_library_indicators": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  }
}
