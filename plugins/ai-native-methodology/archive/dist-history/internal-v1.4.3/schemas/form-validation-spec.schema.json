{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-native-methodology/schemas/form-validation-spec.schema.json",
  "title": "Form Validation Spec ( v1.4 Stage 7-pre 신설)",
  "description": "Deliverable #14. Zod / Yup / Joi / React Hook Form / class-validator / Ajv / Vest 등 form validation 라이브러리 → rules.json fe_validation BR 자동 추출. ADR-FE-005 §2.1.1 (Zod 매개체 13 채택) + ADR-FE-006 (L1 Domain framework-neutral IR) + 외부 LLM 검증 빈틈 #1 해소.",
  "x-spec-source": {
    "zod": "https://zod.dev/",
    "yup": "https://github.com/jquense/yup",
    "joi": "https://joi.dev/",
    "react_hook_form": "https://react-hook-form.com/",
    "class_validator": "https://github.com/typestack/class-validator",
    "ajv": "https://ajv.js.org/",
    "vest": "https://vestjs.dev/"
  },
  "type": "object",
  "required": ["meta", "source_libraries", "validations", "summary"],
  "properties": {
    "meta": { "$ref": "./meta-confidence.schema.json" },
    "source_libraries": {
      "type": "array",
      "description": "감지된 form validation 라이브러리 목록.",
      "items": {
        "type": "object",
        "required": ["library", "detected"],
        "properties": {
          "library": {
            "type": "string",
            "enum": [
              "zod",
              "yup",
              "joi",
              "react_hook_form",
              "class_validator",
              "ajv",
              "vest",
              "manual",
              "unknown"
            ],
            "description": " Zod = primary 권장 (ADR-FE-005 매개체 13). class_validator = NestJS BE+FE 양쪽 사용 가능."
          },
          "library_version": { "type": "string" },
          "detected": { "type": "boolean" },
          "scope_files": {
            "type": "array",
            "items": { "type": "string" }
          },
          "schemas_count": {
            "type": "integer",
            "minimum": 0,
            "description": "추출된 schema 개수 (Zod의 z.object() / Yup의 yup.object() 등)."
          }
        }
      },
      "minItems": 1
    },
    "validations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "field_name", "validation_type", "source_format"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^F-VAL-[A-Z0-9_-]+-\\d+$",
            "description": "Form validation ID. 예: F-VAL-LOGIN-EMAIL-001."
          },
          "field_name": {
            "type": "string",
            "description": "Form field 이름 (예: 'email', 'password', 'username')."
          },
          "form_id": {
            "type": "string",
            "description": " 같은 form 의 다른 field 그룹화 (예: 'LoginForm', 'SignupForm')."
          },
          "validation_type": {
            "type": "string",
            "enum": [
              "required",
              "min_length",
              "max_length",
              "min_value",
              "max_value",
              "pattern",
              "email",
              "url",
              "uuid",
              "datetime",
              "ip",
              "custom_refine",
              "transform",
              "nullable",
              "optional",
              "enum_match",
              "object_shape",
              "array_constraint",
              "tuple_constraint",
              "intersection",
              "union",
              "discriminated_union"
            ],
            "description": " Zod / Yup / Joi 패턴 통합 enum. custom_refine = .refine() / .superRefine() / .test()."
          },
          "rule_value": {
            "description": "Validation rule 값 (min=8, regex pattern, custom function name 등)."
          },
          "error_message": {
            "type": "string",
            "description": "사용자 노출 error message (Zod의 .min(8, '...') 의 두 번째 인자 등)."
          },
          "source_format": {
            "type": "string",
            "enum": [
              "zod",
              "yup",
              "joi",
              "react_hook_form",
              "class_validator",
              "ajv",
              "vest",
              "manual"
            ],
            "description": " 추출 source library."
          },
          "source_file": { "type": "string" },
          "source_line": { "type": "integer", "minimum": 1 },
          "source_snippet": { "type": "string" },
          "cross_link_to_br": {
            "type": "string",
            "pattern": "^BR-[A-Z0-9_-]+-\\d+$",
            "description": " rules.json fe_validation BR auto-extracted ID. (rules.json 자동 등록 후 cross-link)"
          },
          "framework_coupled": {
            "type": "boolean",
            "description": " ADR-FE-006 정합 — React Hook Form rules / Vue useField rules 같이 framework 종속 시 true. true → 신규 스택 정해진 후 재추출 의무."
          },
          "runtime_executable": {
            "type": "boolean",
            "description": " runtime executable 여부 (Zod parse() / Yup validate() 등). true 시 framework-neutral 활용 가능."
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total_validations", "br_auto_extraction_count"],
      "properties": {
        "total_validations": { "type": "integer", "minimum": 0 },
        "per_library": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "per_validation_type": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "br_auto_extraction_count": {
          "type": "integer",
          "minimum": 0,
          "description": " rules.json fe_validation BR 으로 자동 등록된 개수. (rules.json `category=fe_validation` 항목 매칭)"
        },
        "framework_coupled_count": {
          "type": "integer",
          "minimum": 0,
          "description": " framework_coupled=true 인 validation 개수. > 0 시 신규 스택 정해진 후 재추출 의무 표기."
        },
        "captured_by": {
          "type": "string",
          "enum": ["static_extraction", "ts_morph_real", "babel_traverse_real", "simulation"],
          "description": " no-simulation 정책. simulation 시 -5%p 패널티 + simulation_reason 의무."
        },
        "simulation_reason": { "type": "string" }
      }
    },
    "cross_links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from_validation", "to_artifact", "to_id", "link_type"],
        "properties": {
          "from_validation": { "type": "string" },
          "to_artifact": {
            "type": "string",
            "enum": ["rules", "ui-spec", "state-map", "type-spec", "antipatterns"]
          },
          "to_id": { "type": "string" },
          "link_type": {
            "type": "string",
            "enum": [
              "auto_extracted_to_br",
              "validates_field",
              "validates_form_state",
              "type_constrains",
              "registers_as_antipattern"
            ]
          }
        }
      }
    }
  }
}
