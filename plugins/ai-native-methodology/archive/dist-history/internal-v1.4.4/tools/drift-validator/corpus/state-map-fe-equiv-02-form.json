{
  "id": "FSM-FE-FORM-001",
  "initial": "pristine",
  "states": {
    "pristine": { "on": { "INPUT": "dirty" } },
    "dirty": { "on": { "VALIDATE": "validating" } },
    "validating": {
      "on": {
        "SUCCESS": "valid",
        "FAIL": "invalid"
      }
    },
    "invalid": { "on": { "INPUT": "dirty" } },
    "valid": { "on": { "SUBMIT": "submitting" } },
    "submitting": {
      "on": {
        "SUCCESS": "submitted",
        "FAIL": "valid"
      }
    },
    "submitted": { "type": "final", "on": {} }
  }
}
