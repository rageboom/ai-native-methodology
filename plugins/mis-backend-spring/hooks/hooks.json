{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/backend-quality-gate.sh",
            "timeout": 180000,
            "statusMessage": "backend quality gate (spotless/ktlint + compile)..."
          }
        ]
      }
    ]
  }
}
